---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const diagSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    '@id': 'https://sitesespeciais.com.br/diagnostico/#service',
    'name': 'Diagnóstico Gratuito de Site',
    'description': 'Diagnóstico completo do seu site e presença digital. Preencheu o formulário e em até 48 horas úteis você recebe a análise completa no WhatsApp e e-mail. Gratuito, sem compromisso.',
    'url': 'https://sitesespeciais.com.br/diagnostico',
    'provider': { '@id': 'https://sitesespeciais.com.br/#organization' },
    'offers': {
      '@type': 'Offer',
      'price': '0',
      'priceCurrency': 'BRL',
      'availability': 'https://schema.org/InStock',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    'mainEntity': [
      { '@type': 'Question', 'name': 'O diagnóstico é realmente gratuito?', 'acceptedAnswer': { '@type': 'Answer', 'text': 'Sim, sem pegadinha. O diagnóstico não tem custo. Você preenche o formulário e em até 48 horas úteis recebe a análise completa no WhatsApp e e-mail. Se depois quiser uma proposta, aí sim conversamos — mas não é obrigatório.' } },
      { '@type': 'Question', 'name': 'Precisa ter site para solicitar o diagnóstico?', 'acceptedAnswer': { '@type': 'Answer', 'text': 'Não. Se você ainda não tem site, o diagnóstico analisa a sua presença digital atual e o que faz sentido criar para o seu negócio.' } },
      { '@type': 'Question', 'name': 'Em quanto tempo recebo o diagnóstico?', 'acceptedAnswer': { '@type': 'Answer', 'text': 'Em até 48 horas úteis após o preenchimento do formulário, você recebe o diagnóstico completo no WhatsApp e no e-mail informado.' } },
      { '@type': 'Question', 'name': 'Vocês atendem qualquer tipo de empresa?', 'acceptedAnswer': { '@type': 'Answer', 'text': 'Focamos em empresas locais e regionais brasileiras: clínicas, consultórios, escritórios de advocacia, imobiliárias, distribuidoras e prestadores de serviço. Se o seu negócio precisa de autoridade online — é para você.' } },
    ],
  },
];
---

<Layout
  title="Diagnóstico Gratuito — Descubra o que está custando clientes ao seu site | Sites Especiais"
  description="Preencha o formulário em 2 minutos e receba em 48h um diagnóstico completo do seu site. Gratuito, sem compromisso."
  schema={diagSchema}
>
  <Navbar />

  <main style="position: relative; z-index: 1;">

    <!-- HERO -->
    <section class="section diag-hero">
      <div class="perspective-grid" aria-hidden="true"></div>
      <div class="container container--narrow" style="position: relative; z-index: 1;">

        <div class="diag-layout">

          <!-- Coluna esquerda: contexto e passos -->
          <div class="diag-context">
            <p class="eyebrow reveal">Diagnóstico gratuito</p>
            <h1 class="diag__h1 reveal reveal-delay-1">
              Descubra o que está<br>
              <span class="text-gradient">custando clientes</span><br>
              ao seu site.
            </h1>
            <p class="diag__sub reveal reveal-delay-2">
              Preencha o formulário. Em até 48 horas úteis,
              nosso time analisa e envia o resultado direto no seu WhatsApp e e-mail.
            </p>

            <div class="diag-passos reveal reveal-delay-3">
              <div class="diag-passo">
                <div class="diag-passo__num">1</div>
                <div class="diag-passo__text">
                  <strong>Você me conta</strong>
                  <span>o que está travando seu negócio online</span>
                </div>
              </div>
              <div class="diag-passo">
                <div class="diag-passo__num">2</div>
                <div class="diag-passo__text">
                  <strong>Mostramos o que encontramos</strong>
                  <span>em auditoria gratuita do seu site e presença digital</span>
                </div>
              </div>
              <div class="diag-passo">
                <div class="diag-passo__num">3</div>
                <div class="diag-passo__text">
                  <strong>Você sai com clareza</strong>
                  <span>do que precisa ser feito e por que — sem pressão</span>
                </div>
              </div>
            </div>

            <figure class="diag-depo reveal">
              <blockquote>
                <p>"Entrei achando que ia ser uma reunião de venda. Saí com um roteiro do que estava errado no meu site — e a certeza de que era com ele que eu queria trabalhar."</p>
              </blockquote>
              <figcaption>
                <strong>Equipe EmCORR</strong>
                <span>· Centro Clínico — Corrente, PI</span>
              </figcaption>
            </figure>
          </div>

          <!-- Coluna direita: formulário multi-step -->
          <div class="diag-form-wrap reveal reveal-delay-1">

            <!-- Progress bar -->
            <div class="form-progress" id="form-progress" aria-hidden="true">
              <div class="form-progress__bar" id="form-progress-bar"></div>
            </div>
            <div class="form-step-label" id="form-step-label">Passo 1 de 2</div>

            <!-- Step 1: Contexto do negócio -->
            <form id="diag-step1" class="diag-form diag-form--active" novalidate>
              <h2 class="form-heading">Conte sobre o seu negócio</h2>

              <div class="form-group">
                <label class="form-label">Você já tem um site?</label>
                <div class="radio-grid">
                  <label class="radio-card">
                    <input type="radio" name="tem_site" value="sim" required />
                    <span class="radio-card__inner">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
                      Sim, tenho site
                    </span>
                  </label>
                  <label class="radio-card">
                    <input type="radio" name="tem_site" value="nao" required />
                    <span class="radio-card__inner">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
                      Ainda não tenho
                    </span>
                  </label>
                </div>
              </div>

              <div class="form-group" id="url-group" style="display:none;">
                <label for="site_url" class="form-label">Qual é o endereço do seu site?</label>
                <input
                  type="url"
                  id="site_url"
                  name="site_url"
                  class="form-input"
                  placeholder="www.seusite.com.br"
                  autocomplete="url"
                />
              </div>

              <div class="form-group">
                <label for="setor" class="form-label">Qual é o seu setor?</label>
                <div class="select-wrapper">
                  <select id="setor" name="setor" class="form-select" required>
                    <option value="" disabled selected>Selecione seu setor</option>
                    <option value="clinica">Clínica / Consultório</option>
                    <option value="advocacia">Escritório de Advocacia</option>
                    <option value="imobiliaria">Imobiliária</option>
                    <option value="distribuidora">Distribuidora / Atacado</option>
                    <option value="comercio">Comércio / Varejo</option>
                    <option value="servicos">Prestador de Serviços</option>
                    <option value="outro">Outro</option>
                  </select>
                  <svg class="select-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
                </div>
              </div>

              <div class="form-group">
                <label class="form-label">Qual é o principal problema?</label>
                <div class="radio-list">
                  <label class="radio-row">
                    <input type="radio" name="problema" value="invisivel_google" required />
                    <span>Aparece pouco ou nada no Google</span>
                  </label>
                  <label class="radio-row">
                    <input type="radio" name="problema" value="nao_converte" />
                    <span>Recebo visitas mas ninguém entra em contato</span>
                  </label>
                  <label class="radio-row">
                    <input type="radio" name="problema" value="visual_velho" />
                    <span>O visual está desatualizado e afasta clientes</span>
                  </label>
                  <label class="radio-row">
                    <input type="radio" name="problema" value="mobile_ruim" />
                    <span>Não funciona bem no celular</span>
                  </label>
                  <label class="radio-row">
                    <input type="radio" name="problema" value="invisivel_ia" />
                    <span>Não aparece no ChatGPT / Google AI / Gemini</span>
                  </label>
                  <label class="radio-row">
                    <input type="radio" name="problema" value="criar_site" />
                    <span>Quero criar meu primeiro site</span>
                  </label>
                </div>
              </div>

              <div class="form-error" id="step1-error" role="alert" aria-live="polite"></div>

              <button type="submit" class="btn btn--primary btn--full">
                Continuar →
              </button>
            </form>

            <!-- Step 2: Dados de contato -->
            <form id="diag-step2" class="diag-form" novalidate>
              <h2 class="form-heading">Para onde enviamos o diagnóstico?</h2>
              <p class="form-sub">Você recebe o resultado em até 48h úteis.</p>

              <div class="form-group">
                <label for="nome" class="form-label">Seu nome</label>
                <input
                  type="text"
                  id="nome"
                  name="nome"
                  class="form-input"
                  placeholder="João Silva"
                  autocomplete="name"
                  required
                />
              </div>

              <div class="form-group">
                <label for="email" class="form-label">E-mail</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  class="form-input"
                  placeholder="joao@suaempresa.com.br"
                  autocomplete="email"
                  required
                />
              </div>

              <div class="form-group">
                <label for="whatsapp" class="form-label">WhatsApp <span class="form-label__hint">(com DDD)</span></label>
                <input
                  type="tel"
                  id="whatsapp"
                  name="whatsapp"
                  class="form-input"
                  placeholder="(89) 99999-0000"
                  autocomplete="tel"
                  required
                />
              </div>

              <div class="form-error" id="step2-error" role="alert" aria-live="polite"></div>

              <div class="form-actions">
                <button type="button" class="btn btn--ghost" id="back-btn">← Voltar</button>
                <button type="submit" class="btn btn--primary btn--full" id="submit-btn">
                  <span class="submit-text">Quero meu diagnóstico →</span>
                  <span class="submit-loading" style="display:none;">
                    <svg class="spin" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>
                    Enviando…
                  </span>
                </button>
              </div>
            </form>

            <!-- Step 3: Confirmação -->
            <div id="diag-step3" class="diag-form diag-confirm">
              <div class="confirm-icon" aria-hidden="true">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <h2 class="confirm-heading">Diagnóstico solicitado!</h2>
              <p class="confirm-sub" id="confirm-msg">
                Recebemos suas informações. Em até <strong>48 horas úteis</strong>,
                nosso time analisa e envia o resultado direto no seu WhatsApp e e-mail.
              </p>

              <div class="confirm-promise">
                <div class="confirm-promise__item">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  Análise do site e presença digital
                </div>
                <div class="confirm-promise__item">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  Pontos críticos que estão afastando clientes
                </div>
                <div class="confirm-promise__item">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  O que precisa mudar e por onde começar
                </div>
              </div>

              <div class="confirm-divider">
                <span>Quer conversar agora?</span>
              </div>

              <p class="confirm-cal-text">
                Se preferir tirar dúvidas ao vivo, agende uma conversa de 30 minutos.
              </p>

              <a
                href="https://cal.com/raniellevi/30min"
                target="_blank"
                rel="noopener"
                class="btn btn--outline btn--full"
                id="cal-btn"
              >
                Agendar conversa no Cal.com →
              </a>

              <a href="/" class="confirm-home-link">← Voltar para o início</a>
            </div>

          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="section section--alt">
      <div class="container container--narrow">
        <div class="text-center reveal" style="margin-bottom: 2.5rem;">
          <p class="eyebrow">Perguntas frequentes</p>
          <h2 class="section__h2">Antes de preencher.</h2>
        </div>

        <div class="faq-list">
          <details class="faq-item reveal">
            <summary class="faq-item__q">É realmente gratuito?</summary>
            <div class="faq-item__a">
              <p>Sim, sem pegadinha. O diagnóstico não tem custo. Você preenche o formulário e em até 48 horas úteis recebe a análise no WhatsApp e e-mail. Se depois quiser uma proposta, aí sim conversamos — mas não é obrigatório.</p>
            </div>
          </details>

          <details class="faq-item reveal reveal-delay-1">
            <summary class="faq-item__q">Precisa ter site para solicitar?</summary>
            <div class="faq-item__a">
              <p>Não. Se você ainda não tem site, o diagnóstico analisa a sua presença digital atual e o que faz sentido criar para o seu momento.</p>
            </div>
          </details>

          <details class="faq-item reveal reveal-delay-2">
            <summary class="faq-item__q">Como recebo o diagnóstico?</summary>
            <div class="faq-item__a">
              <p>Em até 48 horas úteis após o preenchimento, você recebe o resultado direto no WhatsApp e no e-mail que informou. Sem precisar agendar nada ou esperar uma ligação.</p>
            </div>
          </details>

          <details class="faq-item reveal">
            <summary class="faq-item__q">E se eu quiser seguir em frente?</summary>
            <div class="faq-item__a">
              <p>No diagnóstico já fica claro o que precisa mudar e quanto custa resolver. Se fizer sentido trabalharmos juntos, você nos avisa e seguimos para a proposta. Sem pressão e sem prazo artificialmente curto.</p>
            </div>
          </details>

          <details class="faq-item reveal reveal-delay-1">
            <summary class="faq-item__q">Vocês atendem fora do Brasil?</summary>
            <div class="faq-item__a">
              <p>Sim. Atendemos empresas em toda a América Latina. Nosso foco são negócios locais e regionais brasileiros, mas se você tem uma empresa em outro país de língua portuguesa ou espanhola, entre em contato.</p>
            </div>
          </details>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<script>
  // ── Estado global do formulário ──────────────────────────
  const formData: Record<string, string> = {};

  const step1Form   = document.getElementById('diag-step1') as HTMLFormElement;
  const step2Form   = document.getElementById('diag-step2') as HTMLFormElement;
  const step3Div    = document.getElementById('diag-step3') as HTMLElement;
  const progressBar = document.getElementById('form-progress-bar') as HTMLElement;
  const stepLabel   = document.getElementById('form-step-label') as HTMLElement;
  const urlGroup    = document.getElementById('url-group') as HTMLElement;
  const step1Error  = document.getElementById('step1-error') as HTMLElement;
  const step2Error  = document.getElementById('step2-error') as HTMLElement;
  const backBtn     = document.getElementById('back-btn') as HTMLButtonElement;
  const submitBtn   = document.getElementById('submit-btn') as HTMLButtonElement;

  // Mostrar/ocultar campo de URL conforme resposta
  const temSiteRadios = document.querySelectorAll<HTMLInputElement>('input[name="tem_site"]');
  temSiteRadios.forEach((radio) => {
    radio.addEventListener('change', () => {
      urlGroup.style.display = radio.value === 'sim' ? 'block' : 'none';
      const urlInput = document.getElementById('site_url') as HTMLInputElement;
      urlInput.required = radio.value === 'sim';
    });
  });

  // Mascara WhatsApp
  const whatsappInput = document.getElementById('whatsapp') as HTMLInputElement;
  whatsappInput?.addEventListener('input', (e) => {
    let v = (e.target as HTMLInputElement).value.replace(/\D/g, '');
    if (v.length > 11) v = v.slice(0, 11);
    if (v.length >= 7) {
      v = `(${v.slice(0, 2)}) ${v.slice(2, 7)}-${v.slice(7)}`;
    } else if (v.length >= 3) {
      v = `(${v.slice(0, 2)}) ${v.slice(2)}`;
    } else if (v.length >= 1) {
      v = `(${v}`;
    }
    (e.target as HTMLInputElement).value = v;
  });

  function setProgress(step: number) {
    const pct = step === 1 ? 50 : step === 2 ? 100 : 100;
    progressBar.style.width = `${pct}%`;
    stepLabel.textContent = step < 3 ? `Passo ${step} de 2` : 'Concluído';
  }

  function showStep(n: number) {
    step1Form.classList.toggle('diag-form--active', n === 1);
    step2Form.classList.toggle('diag-form--active', n === 2);
    step3Div.classList.toggle('diag-form--active', n === 3);
    setProgress(n);
  }

  // ── Step 1 submit ────────────────────────────────────────
  step1Form.addEventListener('submit', (e) => {
    e.preventDefault();
    step1Error.textContent = '';

    const fd = new FormData(step1Form);
    const temSite = fd.get('tem_site') as string;
    const setor   = fd.get('setor') as string;
    const problema = fd.get('problema') as string;
    const siteUrl = (fd.get('site_url') as string)?.trim();

    if (!temSite) { step1Error.textContent = 'Selecione se você tem site ou não.'; return; }
    if (!setor)   { step1Error.textContent = 'Selecione seu setor.'; return; }
    if (!problema) { step1Error.textContent = 'Selecione o principal problema.'; return; }
    if (temSite === 'sim' && !siteUrl) { step1Error.textContent = 'Informe o endereço do seu site.'; return; }

    formData['tem_site'] = temSite;
    formData['setor']    = setor;
    formData['problema'] = problema;
    if (siteUrl) formData['site_url'] = siteUrl;

    showStep(2);
    step2Form.querySelector<HTMLInputElement>('#nome')?.focus();
  });

  // ── Back button ──────────────────────────────────────────
  backBtn?.addEventListener('click', () => showStep(1));

  // ── Step 2 submit ────────────────────────────────────────
  step2Form.addEventListener('submit', async (e) => {
    e.preventDefault();
    step2Error.textContent = '';

    const fd = new FormData(step2Form);
    const nome     = (fd.get('nome') as string)?.trim();
    const email    = (fd.get('email') as string)?.trim();
    const whatsapp = (fd.get('whatsapp') as string)?.trim();

    if (!nome)     { step2Error.textContent = 'Informe seu nome.'; return; }
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      step2Error.textContent = 'Informe um e-mail válido.'; return;
    }
    if (!whatsapp || whatsapp.replace(/\D/g, '').length < 10) {
      step2Error.textContent = 'Informe um WhatsApp válido com DDD.'; return;
    }

    formData['nome']     = nome;
    formData['email']    = email;
    formData['whatsapp'] = whatsapp;

    // Loading state
    const submitText    = submitBtn.querySelector('.submit-text') as HTMLElement;
    const submitLoading = submitBtn.querySelector('.submit-loading') as HTMLElement;
    submitBtn.disabled  = true;
    submitText.style.display   = 'none';
    submitLoading.style.display = 'flex';

    try {
      const res = await fetch('/api/lead', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ tipo: 'diagnostico', ...formData }),
      });

      if (!res.ok) throw new Error('Erro no servidor');

      // Atualiza mensagem de confirmação com e-mail e WhatsApp
      const confirmMsg = document.getElementById('confirm-msg');
      if (confirmMsg) {
        confirmMsg.innerHTML = `Recebemos suas informações, <strong>${nome.split(' ')[0]}</strong>. Em até <strong>48 horas úteis</strong>, nosso time analisa e envia o resultado para <strong>${email}</strong> e <strong>${whatsapp}</strong>.`;
      }

      // Personaliza link Cal.com com nome e email
      const calBtn = document.getElementById('cal-btn') as HTMLAnchorElement;
      if (calBtn) {
        const params = new URLSearchParams({ name: nome, email });
        calBtn.href = `https://cal.com/raniellevi/30min?${params}`;
      }

      showStep(3);
    } catch {
      // Mesmo com erro de rede, mostra confirmação (lead já pode estar salvo)
      const confirmMsg = document.getElementById('confirm-msg');
      if (confirmMsg) {
        confirmMsg.innerHTML = `Recebemos suas informações, <strong>${nome.split(' ')[0]}</strong>. Em até <strong>48 horas úteis</strong>, nosso time analisa e envia o resultado para <strong>${email}</strong> e <strong>${whatsapp}</strong>.`;
      }
      showStep(3);
    } finally {
      submitBtn.disabled = false;
      submitText.style.display   = '';
      submitLoading.style.display = 'none';
    }
  });

  // Progress inicial
  setProgress(1);
</script>

<style>
.text-center { text-align: center; }
.section--alt { background: rgba(255,255,255,0.015); }

.eyebrow {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--luxota-accent);
  margin-bottom: 0.75rem;
}

.section__h2 {
  font-size: clamp(1.8rem, 3.5vw, 2.6rem);
  margin-bottom: 1rem;
}

/* ── Hero ─────────────────────────────────────────────────── */
.diag-hero {
  padding-top: 8rem;
  padding-bottom: 5rem;
  position: relative;
  overflow: hidden;
}

.diag-layout {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: start;
}

@media (max-width: 900px) {
  .diag-layout {
    grid-template-columns: 1fr;
    gap: 3rem;
  }
}

/* ── Left column ──────────────────────────────────────────── */
.diag__h1 {
  font-family: 'Playfair Display', serif;
  font-size: clamp(2.2rem, 4.5vw, 3.6rem);
  line-height: 1.08;
  letter-spacing: -0.02em;
  margin-bottom: 1.25rem;
}

.diag__sub {
  font-size: clamp(0.95rem, 1.4vw, 1.05rem);
  color: var(--text-secondary);
  line-height: 1.7;
  margin-bottom: 2.5rem;
}

.diag-passos {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  margin-bottom: 2.5rem;
}

.diag-passo {
  display: flex;
  gap: 1rem;
  align-items: flex-start;
}

.diag-passo__num {
  width: 28px;
  height: 28px;
  background: rgba(240, 208, 96, 0.1);
  border: 1px solid rgba(240, 208, 96, 0.25);
  border-radius: 50%;
  display: flex;
  align-items: center;
