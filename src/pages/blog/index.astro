---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { getAllPosts, type PostSummary } from '../../lib/hygraph';

let posts: PostSummary[] = [];
let erro = false;

try {
  posts = await getAllPosts();
} catch {
  erro = true;
}

function formatarData(dateStr: string) {
  return new Date(dateStr + 'T00:00:00').toLocaleDateString('pt-BR', {
    day: '2-digit',
    month: 'long',
    year: 'numeric',
  });
}
---

<Layout
  title="Blog — Sites Especiais"
  description="Dicas práticas para empresas locais aparecerem no Google, no ChatGPT e venderem mais pelo site."
>
  <Navbar />

  <main style="position: relative; z-index: 1;">
    <section class="section blog-hero">
      <div class="container container--narrow text-center">
        <p class="eyebrow reveal">Blog</p>
        <h1 class="blog-hero__h1 reveal reveal-delay-1">
          Seu site pode trabalhar<br>
          <span class="text-gradient">muito mais por você</span>
        </h1>
        <p class="blog-hero__sub reveal reveal-delay-2">
          Dicas diretas para empresas locais aparecerem no Google,
          atraírem clientes de verdade e pararem de perder dinheiro com site ruim.
        </p>
      </div>
    </section>

    <section class="section" style="padding-top: 0;">
      <div class="container">
        {erro && (
          <div class="blog-erro">
            <p>Não foi possível carregar os posts agora. Tente novamente em instantes.</p>
          </div>
        )}

        {!erro && posts.length === 0 && (
          <div class="blog-vazio">
            <p>Nenhum post publicado ainda. Volte em breve!</p>
          </div>
        )}

        {!erro && posts.length > 0 && (
          <div class="posts-grid">
            {posts.map((post, i) => (
              <article class={`post-card reveal${i % 3 !== 0 ? ` reveal-delay-${(i % 3)}` : ''}`}>
                <a href={`/blog/${post.slug}`} class="post-card__link" tabindex="-1" aria-hidden="true">
                  <div class="post-card__img">
                    {post.coverImage?.url ? (
                      <img
                        src={post.coverImage.url}
                        alt={post.title}
                        loading="lazy"
                        width="640"
                        height="360"
                      />
                    ) : (
                      <div class="post-card__img-placeholder"></div>
                    )}
                  </div>
                </a>

                <div class="post-card__body">
                  {post.category?.length > 0 && (
                    <span class="post-card__cat">{post.category[0].name}</span>
                  )}

                  <h2 class="post-card__title">
                    <a href={`/blog/${post.slug}`}>{post.title}</a>
                  </h2>

                  <p class="post-card__excerpt">{post.excerpt}</p>

                  <div class="post-card__meta">
                    {post.author && <span class="post-card__author">{post.author.name}</span>}
                    <time class="post-card__date" datetime={post.date}>
                      {formatarData(post.date)}
                    </time>
                  </div>

                  <a href={`/blog/${post.slug}`} class="post-card__read">
                    Ler artigo →
                  </a>
                </div>
              </article>
            ))}
          </div>
        )}
      </div>
    </section>

    <!-- CTA blog -->
    <section class="section section--alt">
      <div class="container container--narrow text-center">
        <h2 class="reveal" style="font-size: clamp(1.6rem, 3vw, 2.4rem); margin-bottom: 1rem;">
          Seu site também pode aparecer aqui.
        </h2>
        <p class="reveal reveal-delay-1" style="color: var(--text-secondary); margin-bottom: 2rem; font-size: 1rem;">
          Sites Especiais cria sites que os mecanismos de busca entendem e citam.<br>
          Diagnóstico gratuito, resultado em 14 dias.
        </p>
        <a href="/diagnostico" class="btn btn--primary btn--large reveal reveal-delay-2">
          Diagnóstico Gratuito →
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
.text-center { text-align: center; }

.eyebrow {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--luxota-accent);
  margin-bottom: 0.75rem;
}

.blog-hero { padding-bottom: 3rem; }

.blog-hero__h1 {
  font-size: clamp(2rem, 4.5vw, 3.5rem);
  line-height: 1.1;
  margin-bottom: 1.25rem;
}

.blog-hero__sub {
  font-size: 1rem;
  color: var(--text-secondary);
  line-height: 1.7;
  max-width: 540px;
  margin-inline: auto;
}

.section--alt { background: rgba(255, 255, 255, 0.015); }

/* Grid de posts */
.posts-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
}

@media (max-width: 900px) { .posts-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 540px) { .posts-grid { grid-template-columns: 1fr; } }

.post-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  overflow: hidden;
  transition: border-color 0.3s var(--ease-out), transform 0.3s var(--ease-out), box-shadow 0.3s;
  display: flex;
  flex-direction: column;
}

.post-card:hover {
  border-color: rgba(79, 209, 197, 0.2);
  transform: translateY(-3px);
  box-shadow: 0 16px 40px rgba(0, 0, 0, 0.3);
}

.post-card__img {
  aspect-ratio: 16 / 9;
  overflow: hidden;
  background: var(--bg-raised);
}

.post-card__img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.5s var(--ease-out);
}

.post-card:hover .post-card__img img { transform: scale(1.04); }

.post-card__img-placeholder {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, var(--luxota-bg) 0%, #1a2030 100%);
}

.post-card__body {
  padding: 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
  flex: 1;
}

.post-card__cat {
  font-family: var(--font-mono);
  font-size: 0.68rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--luxota-accent);
}

.post-card__title {
  font-family: var(--font-display);
  font-size: 1.1rem;
  line-height: 1.3;
  font-weight: 400;
}

.post-card__title a {
  color: var(--foreground);
  text-decoration: none;
  transition: color 0.2s;
}

.post-card__title a:hover { color: var(--primary); }

.post-card__excerpt {
  font-size: 0.86rem;
  color: var(--text-secondary);
  line-height: 1.65;
  flex: 1;
}

.post-card__meta {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  flex-wrap: wrap;
  font-size: 0.76rem;
  color: var(--text-muted);
  padding-top: 0.5rem;
  border-top: 1px solid var(--border);
  margin-top: auto;
}

.post-card__author { color: var(--text-secondary); font-weight: 500; }

.post-card__read {
  font-size: 0.84rem;
  font-weight: 600;
  color: var(--luxota-accent);
  text-decoration: none;
  transition: color 0.2s;
  margin-top: 0.25rem;
}

.post-card__read:hover { color: var(--primary); }

.blog-erro,
.blog-vazio {
  text-align: center;
  padding: 4rem 1rem;
  color: var(--text-muted);
  font-size: 0.9rem;
}
</style>
