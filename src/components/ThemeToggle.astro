---
// ThemeToggle — alterna entre dark e light, persiste em localStorage.
// Hidratação acontece via script inline no <head> do Layout pra evitar flash.
---

<button
  class="theme-toggle"
  id="theme-toggle"
  type="button"
  aria-label="Alternar tema"
  title="Alternar tema"
>
  <svg class="theme-icon theme-icon--sun" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="12" r="4"/>
    <path d="M12 2v2"/>
    <path d="M12 20v2"/>
    <path d="m4.93 4.93 1.41 1.41"/>
    <path d="m17.66 17.66 1.41 1.41"/>
    <path d="M2 12h2"/>
    <path d="M20 12h2"/>
    <path d="m6.34 17.66-1.41 1.41"/>
    <path d="m19.07 4.93-1.41 1.41"/>
  </svg>
  <svg class="theme-icon theme-icon--moon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
  </svg>
</button>

<style>
.theme-toggle {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: transparent;
  border: 1px solid var(--border);
  color: var(--foreground);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: border-color 0.3s var(--ease-out), background-color 0.3s var(--ease-out);
  position: relative;
  overflow: hidden;
  flex-shrink: 0;
}

.theme-toggle:hover {
  border-color: var(--primary);
  background: var(--accent-dim);
}

.theme-icon {
  position: absolute;
  transition: opacity 0.3s var(--ease-out), transform 0.4s var(--ease-spring);
}

.theme-icon--sun  { opacity: 0; transform: rotate(-45deg) scale(0.4); color: var(--primary); }
.theme-icon--moon { opacity: 1; transform: rotate(0)      scale(1);   color: var(--foreground); }

:global([data-theme="light"]) .theme-icon--sun  { opacity: 1; transform: rotate(0)     scale(1); }
:global([data-theme="light"]) .theme-icon--moon { opacity: 0; transform: rotate(45deg) scale(0.4); }

@media (max-width: 600px) {
  .theme-toggle { width: 36px; height: 36px; }
}
</style>

<script>
  const btn = document.getElementById('theme-toggle');
  if (btn) {
    btn.addEventListener('click', () => {
      const current = document.documentElement.getAttribute('data-theme') ?? 'dark';
      const next = current === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', next);
      try {
        localStorage.setItem('theme', next);
      } catch { /* localStorage indisponível em modo privado — segue sem persistir */ }
    });
  }
</script>
