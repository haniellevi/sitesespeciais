# Copie este arquivo para .env.local e preencha com seus valores reais
# NUNCA commite .env.local no Git

# Hygraph CMS
# Acesse: hygraph.com → seu projeto → Settings → API Access → Content API
HYGRAPH_ENDPOINT=https://YOUR_REGION.cdn.hygraph.com/content/d5058410389a498194cbbcc443fe0b33/master
HYGRAPH_TOKEN=

# Email transacional (Resend)
RESEND_API_KEY=

# Site
SITE_URL=https://sitesespeciais.com.br

# Analytics (opcional)
PUBLIC_PLAUSIBLE_DOMAIN=sitesespeciais.com.br
