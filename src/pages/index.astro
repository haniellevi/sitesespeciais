---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import SpotlightCard from '../components/SpotlightCard.astro';
import CalculadoraMini from '../components/CalculadoraMini.astro';
import AntesDepois from '../components/AntesDepois.astro';

const homeSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'AggregateRating',
    '@id': 'https://sitesespeciais.com.br/#aggregate-rating',
    'itemReviewed': { '@id': 'https://sitesespeciais.com.br/#organization' },
    'ratingValue': '5',
    'bestRating': '5',
    'worstRating': '1',
    'ratingCount': '12',
    'reviewCount': '12',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    'itemListElement': [
      {
        '@type': 'Review',
        'position': 1,
        'reviewRating': { '@type': 'Rating', 'ratingValue': '5', 'bestRating': '5' },
        'author': { '@type': 'Person', 'name': 'Dr. Carlos Pinheiro' },
        'reviewBody': 'Em dois meses após o novo site, meus agendamentos online triplicaram. Antes recebia 3–4 por semana pelo site. Hoje recebo mais de 15. O investimento se pagou no primeiro mês.',
        'itemReviewed': { '@id': 'https://sitesespeciais.com.br/#organization' },
      },
      {
        '@type': 'Review',
        'position': 2,
        'reviewRating': { '@type': 'Rating', 'ratingValue': '5', 'bestRating': '5' },
        'author': { '@type': 'Organization', 'name': 'Fiel Alimentos' },
        'reviewBody': 'Com o site novo, em menos de dois meses começamos a receber pedidos de distribuidores que nunca tínhamos contatado. O formulário de parceria virou nosso melhor vendedor.',
        'itemReviewed': { '@id': 'https://sitesespeciais.com.br/#organization' },
      },
      {
        '@type': 'Review',
        'position': 3,
        'reviewRating': { '@type': 'Rating', 'ratingValue': '5', 'bestRating': '5' },
        'author': { '@type': 'Organization', 'name': 'EmCORR Centro Clínico' },
        'reviewBody': 'Antes do site, pacientes de cidades vizinhas não sabiam que oferecemos Cardiologia e Neurologia aqui em Corrente. Com o site novo, toda semana chegam pacientes que disseram ter encontrado a clínica pelo Google.',
        'itemReviewed': { '@id': 'https://sitesespeciais.com.br/#organization' },
      },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    '@id': 'https://sitesespeciais.com.br/#website',
    'url': 'https://sitesespeciais.com.br',
    'name': 'Sites Especiais',
    'description': 'Reforma e criação de sites premium para empresas locais brasileiras.',
    'inLanguage': 'pt-BR',
    'publisher': { '@id': 'https://sitesespeciais.com.br/#organization' },
    'potentialAction': {
      '@type': 'SearchAction',
      'target': { '@type': 'EntryPoint', 'urlTemplate': 'https://sitesespeciais.com.br/blog?q={search_term_string}' },
      'query-input': 'required name=search_term_string',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    'mainEntity': [
      { '@type': 'Question', 'name': 'Quanto tempo leva para ficar pronto?', 'acceptedAnswer': { '@type': 'Answer', 'text': '14 dias corridos da aprovação do projeto. Para reformas mais simples, pode ser menos. Você acompanha o progresso dia a dia — sem surpresas no meio do caminho.' } },
      { '@type': 'Question', 'name': 'Preciso ter um site atual para fazer a reforma?', 'acceptedAnswer': { '@type': 'Answer', 'text': 'Não. Se você já tem um site, aproveitamos o que funciona e melhoramos o resto. Se não tem, criamos do zero. O resultado é o mesmo: um site que trabalha por você 24 horas.' } },
      { '@type': 'Question', 'name': 'Vou conseguir atualizar o conteúdo sozinho?', 'acceptedAnswer': { '@type': 'Answer', 'text': 'Sim. Você atualiza textos, fotos e preços sem precisar chamar ninguém. Entregamos com um tutorial em vídeo gravado especificamente para o seu site.' } },
      { '@type': 'Question', 'name': 'Vocês usam IA para criar o site?', 'acceptedAnswer': { '@type': 'Answer', 'text': 'Usamos as ferramentas mais avançadas que existem — incluindo as da era da IA. Mas não é a IA que faz o site. É gente especialista usando ferramentas certas, como pedreiro com britadeira: a obra fica boa nos dois casos, mas com a ferramenta certa fica pronta antes e com menos erro.' } },
      { '@type': 'Question', 'name': 'Como funciona o parcelamento?', 'acceptedAnswer': { '@type': 'Answer', 'text': 'Dividimos em até 10x em todos os cartões de crédito, ou 50% de entrada e 50% na entrega do projeto. Você escolhe o que faz mais sentido. A taxa de parcelamento é do cartão — não cobramos nada extra.' } },
      { '@type': 'Question', 'name': 'Vocês ficam com o domínio e a hospedagem?', 'acceptedAnswer': { '@type': 'Answer', 'text': 'Não. O domínio e a hospedagem ficam 100% no seu nome. Você tem controle total. Somos pagos pelo trabalho de criar — não por manter você preso a um contrato mensal de hospedagem inflada.' } },
      { '@type': 'Question', 'name': 'O que inclui o suporte de 90 dias?', 'acceptedAnswer': { '@type': 'Answer', 'text': 'Ajustes de texto, imagem ou layout que não sejam funcionalidades novas. Se algo der errado tecnicamente, corrigimos em até 24h. Via WhatsApp — sem ticket de suporte, sem fila de atendimento.' } },
      { '@type': 'Question', 'name': 'E se eu não gostar do resultado final?', 'acceptedAnswer': { '@type': 'Answer', 'text': 'Garantia incondicional de 7 dias. Um e-mail e devolvemos 100% do valor pago em até 24h. Sem questionamentos, sem burocracia, sem negociação.' } },
    ],
  },
];
---

<Layout
  title="Sites Especiais — Reforma de Sites e Sites Premium para Empresas Locais"
  description="Reformamos sites antigos e criamos sites premium em até 14 dias. Rápido no celular, visível no Google e no ChatGPT, com garantia de 7 dias."
  schema={homeSchema}
  publishedTime="2026-04-28"
  modifiedTime="2026-04-28"
>
  <Navbar />

  <main style="position: relative; z-index: 1;">

    <!-- ══════════════════════════════════════════════
         S1 — HERO
         ══════════════════════════════════════════════ -->
    <section class="hero section" id="hero">
      <div class="perspective-grid" aria-hidden="true"></div>
      <div class="container container--narrow text-center" style="position: relative; z-index: 1;">

        <div class="badge reveal">
          <span class="badge__dot"></span>
          4 projetos por mês — agenda de maio quase completa
        </div>

        <h1 class="hero__h1 reveal reveal-delay-1">
          Seu concorrente aparece<br>
          quando o cliente pesquisa.<br>
          <span class="text-gradient">O seu site, não.</span>
        </h1>

        <p class="hero__sub reveal reveal-delay-2">
          Em 14 dias, você tem um site que abre antes da paciência acabar,
          aparece no Google — e nas IAs. Feito para trazer clientes,
          não só para existir. Garantia incondicional de 7 dias.
        </p>

        <div class="hero__ctas reveal reveal-delay-3">
          <a href="/diagnostico" class="btn btn--primary btn--large">
            Diagnóstico Gratuito do meu site →
          </a>
          <a
            href="https://wa.me/5589994711318?text=Ol%C3%A1%2C%20quero%20saber%20mais%20sobre%20reforma%20de%20site."
            target="_blank"
            rel="noopener"
            class="btn btn--outline btn--large"
          >
            <svg width="18" height="18" viewBox="0 0 32 32" fill="currentColor" aria-hidden="true" style="flex-shrink:0">
              <path d="M16.004 0h-.008C7.174 0 0 7.176 0 16.004c0 3.5 1.128 6.744 3.046 9.378L1.054 31.29l6.118-1.958A15.932 15.932 0 0016.004 32C24.826 32 32 24.826 32 16.004S24.826 0 16.004 0zm9.334 22.616c-.39 1.1-1.932 2.014-3.164 2.28-.842.18-1.94.322-5.642-1.212-4.738-1.962-7.792-6.778-8.03-7.094-.228-.316-1.916-2.554-1.916-4.872 0-2.318 1.212-3.456 1.642-3.928.39-.428 1.028-.626 1.638-.626.198 0 .376.01.536.018.47.02.706.048 1.016.788.39.926 1.338 3.244 1.456 3.48.118.236.236.554.078.87-.148.326-.278.47-.514.742-.236.272-.46.48-.696.774-.218.254-.462.526-.198.996.264.46 1.174 1.878 2.52 3.044 1.732 1.498 3.192 1.964 3.644 2.182.352.17.772.138 1.046-.158.348-.376.778-.998 1.214-1.614.312-.44.704-.494 1.094-.336.396.148 2.506 1.182 2.936 1.396.43.216.716.322.822.498.104.176.104 1.022-.286 2.122z"/>
            </svg>
            Falar no WhatsApp
          </a>
        </div>

        <div class="hero__proof reveal reveal-delay-4">
          <div class="hero__stars">★★★★★</div>
          <span>+12 sites entregues</span>
          <span class="hero__sep">·</span>
          <span>98% de satisfação</span>
          <span class="hero__sep">·</span>
          <span>Garantia de 7 dias</span>
        </div>

      </div>
    </section>

    <!-- ══════════════════════════════════════════════
         S2 — CALCULADORA MINI
         ══════════════════════════════════════════════ -->
    <CalculadoraMini />

    <!-- ══════════════════════════════════════════════
         S3 — SINTOMAS DE SITE DOENTE
         ══════════════════════════════════════════════ -->
    <section class="section" id="sintomas">
      <div class="container">
        <div class="text-center reveal" style="margin-bottom: 3.5rem;">
          <p class="eyebrow">Diagnóstico</p>
          <h2 class="section__h2">Esses problemas estão custando clientes todo mês</h2>
          <p class="section__sub">Se você reconhece um desses, já é prejuízo. Se reconhece três ou mais, é urgente agir.</p>
        </div>

        <div class="sintomas-grid">
          <SpotlightCard class="sintoma-card reveal">
            <div class="sintoma-num">01</div>
            <h3 class="sintoma-title">Quebrado no celular do cliente</h3>
            <p class="sintoma-desc">7 em cada 10 clientes pesquisam pelo celular. Um site que trava, estica ou esconde o WhatsApp no smartphone não é só feio — é uma porta fechada para a maioria dos seus clientes em potencial.</p>
            <div class="sintoma-custo">70% das visitas saindo antes do contato</div>
          </SpotlightCard>

          <SpotlightCard class="sintoma-card reveal reveal-delay-1">
            <div class="sintoma-num">02</div>
            <h3 class="sintoma-title">O site parece que a empresa fechou</h3>
            <p class="sintoma-desc">Site parado é sinal de empresa parada. O cliente que paga mais pesquisa mais antes de decidir — e abandona na hora que encontra um site desatualizado ou com notícia de dois anos atrás.</p>
            <div class="sintoma-custo">Clientes premium indo para concorrentes atualizados</div>
          </SpotlightCard>

          <SpotlightCard class="sintoma-card reveal reveal-delay-2">
            <div class="sintoma-num">03</div>
            <h3 class="sintoma-title">Invisível para quem está comprando agora</h3>
            <p class="sintoma-desc">Se você não aparece nas primeiras posições do Google quando alguém procura o que você vende, esse cliente não vai te encontrar. Ele vai ao concorrente que aparece — mesmo que o seu serviço seja melhor.</p>
            <div class="sintoma-custo">Zero captação de quem está ativamente procurando</div>
          </SpotlightCard>

          <SpotlightCard class="sintoma-card reveal">
            <div class="sintoma-num">04</div>
            <h3 class="sintoma-title">Perdido nos primeiros 3 segundos</h3>
            <p class="sintoma-desc">53% dos visitantes desistem se o site demora mais de 3 segundos para abrir. Cada segundo extra é uma porta que se fecha. O cliente clicou no link — e você perdeu a chance antes de qualquer palavra.</p>
            <div class="sintoma-custo">Estimativa: R$ 2.000–8.000/mês em leads que vão embora</div>
          </SpotlightCard>

          <SpotlightCard class="sintoma-card reveal reveal-delay-1">
            <div class="sintoma-num">05</div>
            <h3 class="sintoma-title">O contato que nunca chegou</h3>
            <p class="sintoma-desc">Se o WhatsApp não está visível na primeira tela ou exige dois cliques, o cliente desiste. Não por preguiça — porque o próximo resultado no Google está a um clique de distância.</p>
            <div class="sintoma-custo">40%+ dos leads que nunca chegam a te chamar</div>
          </SpotlightCard>

          <SpotlightCard class="sintoma-card reveal reveal-delay-2">
            <div class="sintoma-num">06</div>
            <h3 class="sintoma-title">Não existe na nova internet</h3>
            <p class="sintoma-desc">Em 2026, o cliente pesquisa no Google e nas IAs — ChatGPT, Gemini, Perplexity. Sites antigos não são citados. Você pode ser o melhor do seu setor e ser completamente invisível onde uma geração inteira pesquisa.</p>
            <div class="sintoma-custo">Invisível para uma internet que cresce 40% ao ano</div>
          </SpotlightCard>
        </div>

        <div class="text-center" style="margin-top: 3rem;">
          <a href="/diagnostico" class="btn btn--primary btn--large reveal">
            Ver o diagnóstico do meu site →
          </a>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════════
         S3.5 — MINI PROVA SOCIAL (entre sintomas e casos)
         ══════════════════════════════════════════════ -->
    <section class="section-mini-prova" aria-label="Depoimento de cliente">
      <div class="container container--narrow">
        <div class="mini-prova-card reveal">
          <div class="mini-prova-stars">★★★★★</div>
          <blockquote class="mini-prova-quote">
            "Em dois meses após a reforma, meus agendamentos online triplicaram.
            Antes recebia 3–4 por semana pelo site — hoje recebo mais de 15.
            O investimento se pagou no primeiro mês."
          </blockquote>
          <div class="mini-prova-autor">
            <div class="mini-prova-avatar">CP</div>
            <div>
              <strong>Dr. Carlos Pinheiro</strong>
              <span>Clínica Pinheiro · Bom Jesus, PI — <em>reforma de site</em></span>
            </div>
          </div>
          <a href="/diagnostico" class="mini-prova-cta">
            Quero o mesmo resultado para o meu site →
          </a>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════════
         S4 — ANTES / DEPOIS
         ══════════════════════════════════════════════ -->
    <AntesDepois />

    <!-- ══════════════════════════════════════════════
         S5 — COMO FAZEMOS
         ══════════════════════════════════════════════ -->
    <section class="section" id="como-funciona">
      <div class="container">
        <div class="text-center reveal" style="margin-bottom: 3.5rem;">
          <p class="eyebrow">O processo</p>
          <h2 class="section__h2">Do diagnóstico ao ar em 14 dias</h2>
          <p class="section__sub">Sem reuniões intermináveis. Sem jargão técnico. Sem surpresas no bolso.</p>
        </div>

        <div class="processo-steps">
          <div class="step reveal">
            <div class="step-number">01</div>
            <div class="step-content">
              <h3 class="step-title">Diagnóstico gratuito</h3>
              <p class="step-desc">Analisamos seu site atual e identificamos o que está custando clientes. Em 24h você recebe um relatório claro com prioridades e estimativa — sem compromisso.</p>
            </div>
          </div>

          <div class="step-connector" aria-hidden="true"></div>

          <div class="step reveal reveal-delay-1">
            <div class="step-number">02</div>
            <div class="step-content">
              <h3 class="step-title">Aprovação do design</h3>
              <p class="step-desc">Você vê como vai ficar antes de começarmos. Mostramos o visual completo para aprovação. Não gostou de algum detalhe? Ajustamos até você aprovar.</p>
            </div>
          </div>

          <div class="step-connector" aria-hidden="true"></div>

          <div class="step reveal reveal-delay-2">
            <div class="step-number">03</div>
            <div class="step-content">
              <h3 class="step-title">Execução dedicada</h3>
              <p class="step-desc">Nossa equipe constrói seu site com atenção a cada detalhe: velocidade, mobile perfeito, aparecendo no Google desde o primeiro dia no ar.</p>
            </div>
          </div>

          <div class="step-connector" aria-hidden="true"></div>

          <div class="step reveal reveal-delay-3">
            <div class="step-number">04</div>
            <div class="step-content">
              <h3 class="step-title">No ar em 14 dias</h3>
              <p class="step-desc">Site publicado, domínio configurado, e-mail profissional funcionando. Você recebe tudo pronto com um tutorial em vídeo — e 90 dias de suporte via WhatsApp.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════════
         S6 — POR QUE NOSSOS SITES VENDEM MAIS
         ══════════════════════════════════════════════ -->
    <section class="section section--alt" id="diferenciais">
      <div class="container">
        <div class="text-center reveal" style="margin-bottom: 3.5rem;">
          <p class="eyebrow">Diferenciais</p>
          <h2 class="section__h2">Por que nossos sites vendem mais</h2>
          <p class="section__sub">A diferença entre um site que enfeita e um site que trabalha por você 24 horas por dia.</p>
        </div>

        <div class="diferenciais-grid">
          <SpotlightCard class="diferencial-card reveal">
            <div class="diferencial-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
              </svg>
            </div>
            <h3 class="diferencial-title">Abre antes do cliente perder a paciência</h3>
            <p class="diferencial-desc">Nossos sites carregam em menos de 1 segundo no 4G ruim — o mesmo que o app do seu banco. É respeito pelo tempo do cliente e dinheiro no seu bolso, não tecnologia de vitrine.</p>
          </SpotlightCard>

          <SpotlightCard class="diferencial-card reveal reveal-delay-1">
            <div class="diferencial-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="10"/>
                <circle cx="12" cy="12" r="3"/>
                <line x1="12" y1="2" x2="12" y2="5"/>
                <line x1="12" y1="19" x2="12" y2="22"/>
                <line x1="2" y1="12" x2="5" y2="12"/>
                <line x1="19" y1="12" x2="22" y2="12"/>
              </svg>
            </div>
            <h3 class="diferencial-title">Aparece no Google e nas IAs</h3>
            <p class="diferencial-desc">O Google entende seu site na primeira visita. E as IAs te citam quando alguém pergunta sobre o seu setor. Você existe nos dois mundos — enquanto a maioria dos concorrentes não existe em nenhum.</p>
          </SpotlightCard>

          <SpotlightCard class="diferencial-card reveal reveal-delay-2">
            <div class="diferencial-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              </svg>
            </div>
            <h3 class="diferencial-title">Design que convence antes de falar uma palavra</h3>
            <p class="diferencial-desc">Clientes julgam sua empresa em menos de 1 segundo. Aquela sensação de estar num site que transmite confiança — mas é o seu site, com a sua marca, gerando autoridade para o seu negócio.</p>
          </SpotlightCard>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════════
         S7 — ÂNCORA DE PREÇO
         ══════════════════════════════════════════════ -->
    <section class="section" id="precos">
      <div class="container">
        <div class="text-center reveal" style="margin-bottom: 3.5rem;">
          <p class="eyebrow">Investimento</p>
          <h2 class="section__h2">Quanto vale parar de perder clientes?</h2>
          <p class="section__sub">Menos do que você perde em um mês com o site que tem hoje.</p>
        </div>

        <div class="precos-grid">
          <div class="preco-card reveal">
            <p class="preco-label">Já tenho site</p>
            <h3 class="preco-tipo">Reforma de Site</h3>
            <p class="preco-desc">Seu site atual fica irreconhecível — melhor em tudo. Mesmo domínio, nova identidade, velocidade e conversão.</p>
            <div class="preco-valor">
              <span class="preco-from">A partir de</span>
              <span class="preco-num">R$ 1.997</span>
            </div>
            <ul class="preco-items">
              <li>Design novo e exclusivo</li>
              <li>Perfeito em qualquer celular</li>
              <li>Carrega em menos de 1 segundo</li>
              <li>Aparece no Google e nas IAs</li>
              <li>WhatsApp integrado</li>
              <li>90 dias de suporte direto</li>
            </ul>
            <a href="/diagnostico" class="btn btn--primary" style="width: 100%; justify-content: center;">
              Quero reformar meu site →
            </a>
          </div>

          <div class="preco-card preco-card--premium reveal reveal-delay-1">
            <p class="preco-label">Quero um site novo</p>
            <h3 class="preco-tipo">Site Novo do Zero</h3>
            <p class="preco-desc">Construído do zero para converter visitantes em clientes. Identidade completa, animações premium, performance máxima.</p>
            <div class="preco-valor">
              <span class="preco-from">A partir de</span>
              <span class="preco-num">R$ 2.997</span>
            </div>
            <ul class="preco-items">
              <li>Identidade visual criada do zero</li>
              <li>Animações que transmitem autoridade</li>
              <li>Blog integrado para SEO</li>
              <li>Formulários inteligentes</li>
              <li>Aparece no Google e nas IAs</li>
              <li>90 dias de suporte direto</li>
            </ul>
            <a href="/diagnostico" class="btn btn--primary" style="width: 100%; justify-content: center;">
              Quero um site novo →
            </a>
          </div>
        </div>

        <div class="text-center reveal" style="margin-top: 1.5rem;">
          <p style="color: var(--text-muted); font-size: 0.84rem;">
            Garantia incondicional de 7 dias. Se não ficar do jeito que você imaginou, devolvemos 100% do valor — sem burocracia.
          </p>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════════
         S8 — DEPOIMENTOS
         ══════════════════════════════════════════════ -->
    <section class="section section--alt" id="depoimentos">
      <div class="container">
        <div class="text-center reveal" style="margin-bottom: 3.5rem;">
          <p class="eyebrow">Depoimentos</p>
          <h2 class="section__h2">Quem viu a diferença não volta atrás</h2>
        </div>

        <div class="depoimentos-grid">
          <SpotlightCard class="depoimento-card reveal">
            <div class="depoimento-stars">★★★★★</div>
            <p class="depoimento-texto">"Em dois meses, meus agendamentos triplicaram — de 4 por semana para mais de 15. O investimento se pagou no primeiro mês. Hoje me pergunto por que não fiz isso antes."</p>
            <div class="depoimento-autor">
