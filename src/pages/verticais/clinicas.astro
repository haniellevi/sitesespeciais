---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import SpotlightCard from '../../components/SpotlightCard.astro';
---

<Layout
  title="Sites para Clínicas e Consultórios — Mais Consultas, Mais Autoridade | Sites Especiais"
  description="Seu consultório merece um site que passa confiança antes do paciente ligar. Sites que aparecem no Google, no WhatsApp e no ChatGPT. A partir de R$ 1.997 com garantia de 7 dias."
>
  <Navbar />

  <main style="position: relative; z-index: 1;">

    <!-- HERO -->
    <section class="hero-clinicas section">
      <div class="perspective-grid" aria-hidden="true"></div>
      <div class="container container--narrow text-center" style="position: relative; z-index: 1;">

        <div class="badge reveal">
          <span class="badge__dot"></span>
          Para clínicas, consultórios e profissionais da saúde
        </div>

        <h1 class="hero__h1 reveal reveal-delay-1">
          Paciente novo pesquisa no Google<br>
          antes de ligar.<br>
          <span class="text-gradient">O que ele encontra no seu?</span>
        </h1>

        <p class="hero__sub reveal reveal-delay-2">
          Site lento, sem foto profissional, sem avaliações — e o paciente liga para a clínica
          do lado. Você perde antes de ter chance de falar com ele.
          A gente muda isso em até 21 dias.
        </p>

        <div class="hero__ctas reveal reveal-delay-3">
          <a href="/diagnostico" class="btn btn--primary btn--large">
            Diagnóstico Gratuito da minha clínica →
          </a>
          <a href="/cases" class="btn btn--outline btn--large">
            Ver resultados reais
          </a>
        </div>

        <div class="hero__proof reveal reveal-delay-4">
          <div class="hero__stars">★★★★★</div>
          <span>A partir de R$ 1.997</span>
          <span class="hero__sep">·</span>
          <span>Garantia 7 dias</span>
          <span class="hero__sep">·</span>
          <span>Pronto em até 21 dias</span>
        </div>
      </div>
    </section>

    <!-- SINTOMAS ESPECÍFICOS DA VERTICAL -->
    <section class="section section--alt">
      <div class="container">
        <div class="text-center reveal" style="margin-bottom: 3rem;">
          <p class="eyebrow">O diagnóstico do seu site</p>
          <h2 class="section__h2">Seu site está afastando pacientes — e você nem sabe.</h2>
        </div>

        <div class="sintomas-grid">
          <SpotlightCard class="sintoma-card reveal">
            <div class="sintoma-card__inner">
              <div class="sintoma-icon">⏳</div>
              <h3>Abre devagar no celular</h3>
              <p>Em 3 segundos o paciente desistiu. Não importa se você é o melhor da cidade.</p>
            </div>
          </SpotlightCard>

          <SpotlightCard class="sintoma-card reveal reveal-delay-1">
            <div class="sintoma-card__inner">
              <div class="sintoma-icon">📍</div>
              <h3>Não aparece no Google Maps</h3>
              <p>"Clínica perto de mim" — se você não aparece, o paciente vai para quem aparece.</p>
            </div>
          </SpotlightCard>

          <SpotlightCard class="sintoma-card reveal reveal-delay-2">
            <div class="sintoma-card__inner">
              <div class="sintoma-icon">📱</div>
              <h3>Sem agendamento online</h3>
              <p>8 em cada 10 pacientes preferem agendar sem ligar. Sem esse recurso, você já perdeu.</p>
            </div>
          </SpotlightCard>

          <SpotlightCard class="sintoma-card reveal">
            <div class="sintoma-card__inner">
              <div class="sintoma-icon">🏥</div>
              <h3>Parece amador demais</h3>
              <p>Design antigo passa insegurança. Paciente pensa: "se o site é assim, como será o atendimento?"</p>
            </div>
          </SpotlightCard>

          <SpotlightCard class="sintoma-card reveal reveal-delay-1">
            <div class="sintoma-card__inner">
              <div class="sintoma-icon">🤖</div>
              <h3>Invisível no ChatGPT e Gemini</h3>
              <p>"Me recomende uma clínica de odontologia em [cidade]" — se você não aparece, não existe.</p>
            </div>
          </SpotlightCard>

          <SpotlightCard class="sintoma-card reveal reveal-delay-2">
            <div class="sintoma-card__inner">
              <div class="sintoma-icon">⭐</div>
              <h3>Sem mostrar suas avaliações</h3>
              <p>Você tem pacientes satisfeitos, mas o site não mostra isso. A confiança morre antes de começar.</p>
            </div>
          </SpotlightCard>
        </div>
      </div>
    </section>

    <!-- O QUE FAZEMOS -->
    <section class="section">
      <div class="container container--narrow">
        <div class="text-center reveal" style="margin-bottom: 3rem;">
          <p class="eyebrow">O que entregamos</p>
          <h2 class="section__h2">Um site que trabalha enquanto você atende.</h2>
        </div>

        <div class="entrega-grid">
          <div class="entrega-item reveal">
            <div class="entrega-num">01</div>
            <div>
              <h3>Design que passa autoridade médica</h3>
              <p>Fotos profissionais valorizadas, cores que transmitem confiança, tipografia que comunica seriedade. O paciente sente que está no lugar certo antes de ligar.</p>
            </div>
          </div>
          <div class="entrega-item reveal reveal-delay-1">
            <div class="entrega-num">02</div>
            <div>
              <h3>Abre em menos de 1 segundo no celular</h3>
              <p>A maioria dos pacientes pesquisa no celular em 4G. Seu site precisa abrir na hora — ou eles vão para a próxima opção.</p>
            </div>
          </div>
          <div class="entrega-item reveal reveal-delay-2">
            <div class="entrega-num">03</div>
            <div>
              <h3>Google e ChatGPT te encontram</h3>
              <p>Configuramos o site para que o Google entenda o que você faz, onde você fica e para quem. O mesmo para as IAs que os pacientes já usam.</p>
            </div>
          </div>
          <div class="entrega-item reveal">
            <div class="entrega-num">04</div>
            <div>
              <h3>WhatsApp com 1 clique</h3>
              <p>Botão flutuante em todas as páginas. O paciente decide na hora — e a mensagem já vem com contexto do que ele estava vendo.</p>
            </div>
          </div>
          <div class="entrega-item reveal reveal-delay-1">
            <div class="entrega-num">05</div>
            <div>
              <h3>Agendamento integrado</h3>
              <p>Calendário que o paciente acessa direto do site. Sem ligação, sem WhatsApp, sem espera por confirmação manual.</p>
            </div>
          </div>
          <div class="entrega-item reveal reveal-delay-2">
            <div class="entrega-num">06</div>
            <div>
              <h3>Depoimentos que convencem</h3>
              <p>Seção de avaliações que transforma o que seus pacientes falam em argumento de venda antes mesmo da consulta.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CASE/DEPOIMENTO -->
    <section class="section section--alt">
      <div class="container container--narrow">
        <div class="text-center reveal" style="margin-bottom: 2.5rem;">
          <p class="eyebrow">Resultado real</p>
          <h2 class="section__h2">Clínica Pinheiro — de site velho para referência local.</h2>
        </div>

        <div class="case-card reveal">
          <div class="case-card__metricas">
            <div class="case-metrica">
              <span class="case-metrica__num">+3x</span>
              <span class="case-metrica__label">mais contatos pelo site</span>
            </div>
            <div class="case-metrica">
              <span class="case-metrica__num">14</span>
              <span class="case-metrica__label">dias para o ar</span>
            </div>
            <div class="case-metrica">
              <span class="case-metrica__num">1ª</span>
              <span class="case-metrica__label">posição no Google local</span>
            </div>
          </div>
          <figure class="case-card__depo">
            <blockquote>
              <p>
                "Entrei com medo — todo fornecedor promete, ninguém cumpre. Quando vi a garantia de 7 dias,
                falei: pelo menos se não prestar eu recupero o dinheiro. Precisei? Não.
                O site ficou melhor do que eu imaginava."
              </p>
            </blockquote>
            <figcaption>
              <strong>Dra. Ana Clara Fonseca</strong>
              <span>· Clínica Pinheiro</span>
            </figcaption>
          </figure>
        </div>

        <div class="text-center" style="margin-top: 1.5rem;">
          <a href="/cases" class="btn btn--outline">Ver todos os cases →</a>
        </div>
      </div>
    </section>

    <!-- PREÇOS -->
    <section class="section">
      <div class="container container--narrow">
        <div class="text-center reveal" style="margin-bottom: 2.5rem;">
          <p class="eyebrow">Investimento</p>
          <h2 class="section__h2">Quanto custa perder um paciente por dia?</h2>
          <p class="section__sub">
            Um consultório com ticket médio de R$ 300 que perde 2 pacientes/dia por causa do site
            está jogando fora R$ 600 por dia — R$ 18.000 por mês.
            O site custa menos que um mês dessas perdas.
          </p>
        </div>

        <div class="preco-options reveal">
          <div class="preco-opt">
            <p class="preco-opt__tipo">Reforma do site atual</p>
            <div class="preco-opt__valor">R$ 1.997</div>
            <p class="preco-opt__parcela">ou 10x de R$ 199,70</p>
            <p class="preco-opt__prazo">Pronto em 14 dias</p>
            <a href="/reforma" class="btn btn--outline preco-opt__cta">Saiba mais →</a>
          </div>
          <div class="preco-opt preco-opt--destaque">
            <div class="preco-opt__badge">Mais completo</div>
            <p class="preco-opt__tipo">Site novo premium</p>
            <div class="preco-opt__valor">R$ 2.997</div>
            <p class="preco-opt__parcela">ou 10x de R$ 299,70</p>
            <p class="preco-opt__prazo">Pronto em 21 dias</p>
            <a href="/site-novo" class="btn btn--primary preco-opt__cta">Saiba mais →</a>
          </div>
        </div>

        <div class="garantia-strip reveal" style="margin-top: 2rem;">
          <span class="garantia-strip__icon">🛡️</span>
          <div>
            <strong>Garantia incondicional de 7 dias</strong>
            <p>Se não ficar do jeito que você imaginou, devolvemos 100% do valor. Sem burocracia.</p>
          </div>
          <a href="/garantia" class="garantia-strip__link">Como funciona →</a>
        </div>
      </div>
    </section>

    <!-- CTA FINAL -->
    <section class="section cta-final">
      <div class="perspective-grid" aria-hidden="true" style="opacity: 0.2;"></div>
      <div class="container container--narrow text-center" style="position: relative; z-index: 1;">

        <div class="badge reveal">
          <span class="badge__dot"></span>
          Diagnóstico gratuito · Sem compromisso
        </div>

        <h2 class="cta-final__h2 reveal reveal-delay-1">
          Enquanto você lê isso,<br>
          <span class="text-gradient-gold">algum paciente foi para o concorrente.</span>
        </h2>

        <p class="cta-final__sub reveal reveal-delay-2">
          30 minutos de diagnóstico gratuito. Descubra exatamente o que está impedindo
          pacientes novos de chegarem até você — e o que fazemos para mudar isso.
        </p>

        <div class="hero__ctas reveal reveal-delay-3">
          <a href="/diagnostico" class="btn btn--primary btn--large">
            Diagnóstico Gratuito →
          </a>
          <a href="https://wa.me/5589994711318" target="_blank" rel="noopener" class="btn btn--outline btn--large">
            Falar no WhatsApp
          </a>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style>
.text-center { text-align: center; }
.section--alt { background: rgba(255,255,255,0.015); }

.eyebrow {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--luxota-accent);
  margin-bottom: 0.75rem;
}

.section__h2 {
  font-size: clamp(1.8rem, 3.5vw, 2.6rem);
  margin-bottom: 1rem;
}

.section__sub {
  font-size: clamp(0.95rem, 1.4vw, 1.05rem);
  color: var(--text-secondary);
  line-height: 1.7;
  max-width: 580px;
  margin-inline: auto;
}

/* Hero */
.hero-clinicas {
  padding-top: 9rem;
  padding-bottom: 5rem;
  position: relative;
  overflow: hidden;
  min-height: 100svh;
  display: flex;
  align-items: center;
}

.hero__h1 {
  font-family: 'Playfair Display', serif;
  font-size: clamp(2.4rem, 5.5vw, 4.2rem);
  line-height: 1.08;
  letter-spacing: -0.02em;
  margin-bottom: 1.5rem;
}

.hero__sub {
  font-size: clamp(1rem, 1.5vw, 1.15rem);
  color: var(--text-secondary);
  line-height: 1.7;
  max-width: 560px;
  margin-inline: auto;
  margin-bottom: 2.5rem;
}

.hero__ctas {
  display: flex;
  flex-wrap: wrap;
  gap: 1rem;
  justify-content: center;
  margin-bottom: 2.5rem;
}

.hero__proof {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.75rem;
  flex-wrap: wrap;
  font-size: 0.84rem;
  color: var(--text-muted);
}

.hero__stars { color: var(--primary); letter-spacing: 0.05em; }
.hero__sep { opacity: 0.3; }

/* Sintomas */
.sintomas-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 1.25rem;
}

:global(.sintoma-card) {
  padding: 0;
  cursor: default;
}

.sintoma-card__inner {
  padding: 1.75rem;
}

.sintoma-icon {
  font-size: 1.75rem;
  margin-bottom: 0.75rem;
  display: block;
}

:global(.sintoma-card) h3 {
  font-size: 1rem;
  font-weight: 700;
  color: var(--foreground);
  margin-bottom: 0.4rem;
  line-height: 1.3;
}

:global(.sintoma-card) p {
  font-size: 0.87rem;
  color: var(--text-secondary);
  line-height: 1.6;
  margin: 0;
}

/* Entregas */
.entrega-grid {
  display: flex;
  flex-direction: column;
  gap: 1.75rem;
}

.entrega-item {
  display: flex;
  gap: 1.5rem;
  align-items: flex-start;
}

.entrega-num {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  font-weight: 700;
  color: var(--primary);
  opacity: 0.5;
  padding-top: 0.25rem;
  flex-shrink: 0;
  min-width: 1.5rem;
}

.entrega-item h3 {
  font-size: 1rem;
  font-weight: 700;
  color: var(--foreground);
  margin-bottom: 0.35rem;
  line-height: 1.3;
}

.entrega-item p {
  font-size: 0.87rem;
  color: var(--text-secondary);
  line-height: 1.7;
  margin: 0;
}

/* Case card */
.case-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--radius-xl);
  overflow: hidden;
}

.case-card__metricas {
  display: flex;
  justify-content: center;
  gap: 3rem;
  padding: 2rem 2.5rem;
  background: rgba(232, 197, 71, 0.04);
  border-bottom: 1px solid rgba(232, 197, 71, 0.12);
  flex-wrap: wrap;
}

.case-metrica {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.25rem;
}

.case-metrica__num {
  font-family: 'Space Grotesk', monospace;
  font-size: clamp(1.8rem, 3vw, 2.5rem);
  font-weight: 700;
  color: var(--primary);
  line-height: 1;
}

.case-metrica__label {
  font-size: 0.78rem;
  color: var(--text-muted);
  text-align: center;
}

.case-card__depo {
  padding: 2rem 2.5rem;
  margin: 0;
}

.case-card__depo blockquote p {
  font-family: 'Instrument Serif', serif;
  font-size: clamp(1rem, 1.6vw, 1.2rem);
  line-height: 1.65;
  color: var(--foreground);
  margin: 0 0 1.25rem;
  font-style: italic;
}

.case-card__depo blockquote p::before { content: '\201C'; }
.case-card__depo blockquote p::after  { content: '\201D'; }

.case-card__depo figcaption {
  font-size: 0.86rem;
  color: var(--text-muted);
}

.case-card__depo figcaption strong {
  color: var(--foreground);
  font-weight: 600;
}

/* Preços */
.preco-options {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.25rem;
}

@media (max-width: 640px) {
  .preco-options { grid-template-columns: 1fr; }
}

.preco-opt {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--radius-xl);
  padding: 2rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 0.35rem;
  position: relative;
}

.preco-opt--destaque {
  border-color: rgba(232, 197, 71, 0.4);
  background: rgba(232, 197, 71, 0.03);
  box-shadow: 0 0 60px rgba(232, 197, 71, 0.06);
}

.preco-opt__badge {
  position: absolute;
  top: -0.75rem;
  left: 50%;
  transform: translateX(-50%);
  background: var(--primary);
  color: #000;
  font-family: var(--font-mono);
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 0.25rem 0.85rem;
  border-radius: 999px;
  white-space: nowrap;
}

.preco-opt__tipo {
  font-size: 0.84rem;
  color: var(--text-muted);
  margin: 0;
}

.preco-opt__valor {
  font-family: 'Space Grotesk', monospace;
  font-size: clamp(2rem, 4vw, 2.8rem);
  font-weight: 700;
  color: var(--primary);
  line-height: 1;
  margin: 0.25rem 0;
}

.preco-opt__parcela {
  font-size: 0.82rem;
  color: var(--text-muted);
  margin: 0;
}

.preco-opt__prazo {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  color: var(--luxota-accent);
  letter-spacing: 0.08em;
  margin: 0.25rem 0 0.75rem;
}

.preco-opt__cta { width: 100%; justify-content: center; }

/* Garantia strip */
.garantia-strip {
  background: var(--card);
  border: 1px solid rgba(232, 197, 71, 0.2);
  border-radius: var(--radius-lg);
  padding: 1.25rem 1.5rem;
  display: flex;
  align-items: center;
  gap: 1rem;
}

.garantia-strip__icon { font-size: 1.5rem; flex-shrink: 0; }

.garantia-strip strong {
  display: block;
  font-size: 0.93rem;
  color: var(--foreground);
  margin-bottom: 0.15rem;
}

.garantia-strip p {
  font-size: 0.82rem;
  color: var(--text-muted);
  margin: 0;
  line-height: 1.5;
}

.garantia-strip__link {
  margin-left: auto;
  font-size: 0.82rem;
  color: var(--primary);
  white-space: nowrap;
  text-decoration: none;
  font-weight: 600;
  flex-shrink: 0;
}

.garantia-strip__link:hover { text-decoration: underline; }

/* CTA final */
.cta-final {
  position: relative;
  overflow: hidden;
}

.cta-final__h2 {
  font-family: 'Playfair Display', serif;
  font-size: clamp(2rem, 4.5vw, 3.5rem);
  line-height: 1.1;
  margin-bottom: 1.25rem;
}

.cta-final__sub {
  font-size: 1rem;
  color: var(--text-secondary);
  line-height: 1.7;
  max-width: 500px;
  margin-inline: auto;
  margin-bottom: 2.5rem;
}
</style>
