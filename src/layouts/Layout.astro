---
import '@fontsource/dm-sans/400.css';
import '@fontsource/dm-sans/500.css';
import '@fontsource/dm-sans/600.css';
import '@fontsource/dm-sans/700.css';
import '@fontsource/playfair-display/400.css';
import '@fontsource/playfair-display/700.css';
import '@fontsource/space-grotesk/400.css';
import '@fontsource/space-grotesk/600.css';
import '@fontsource/instrument-serif/400.css';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title,
  description = 'Reformamos sites antigos e criamos sites premium para empresas locais que querem dominar o Google e parar de perder clientes para concorrentes piores.',
  ogImage = '/og-default.jpg',
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:site_name" content="Sites Especiais" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Schema.org LocalBusiness -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        "name": "Sites Especiais",
        "description": "Agência de criação e reforma de sites premium para empresas locais. Sites rápidos, exclusivos, que aparecem no Google e convertem visitantes em clientes.",
        "url": "https://sitesespeciais.com.br",
        "email": "contato@sitesespeciais.com.br",
        "telephone": "+5589994711318",
        "areaServed": "BR",
        "serviceType": ["Criação de Sites", "Reforma de Sites", "Sites Premium", "SEO Local"],
        "priceRange": "R$1.997 - R$9.997",
        "slogan": "Feito para Gerar Autoridade"
      }
    </script>
  </head>

  <body>
    <!-- Cursor personalizado (desktop only) -->
    <div class="cursor-dot" id="cursor-dot" aria-hidden="true"></div>
    <div class="cursor-outline" id="cursor-outline" aria-hidden="true"></div>

    <!-- Background animado Luxota -->
    <div class="ambient-light" aria-hidden="true">
      <div class="blob blob-1"></div>
      <div class="blob blob-2"></div>
      <div class="blob blob-3"></div>
    </div>

    <slot />

    <!-- WhatsApp flutuante -->
    <a
      href="https://wa.me/5589994711318?text=Olá!%20Quero%20saber%20mais%20sobre%20reforma%20de%20site."
      class="whatsapp-float"
      target="_blank"
      rel="noopener"
      aria-label="Fale conosco pelo WhatsApp"
    >
      <svg viewBox="0 0 32 32" width="28" height="28" fill="currentColor" aria-hidden="true">
        <path d="M16.004 0h-.008C7.174 0 0 7.176 0 16.004c0 3.5 1.128 6.744 3.046 9.378L1.054 31.29l6.118-1.958A15.932 15.932 0 0016.004 32C24.826 32 32 24.826 32 16.004S24.826 0 16.004 0zm9.334 22.616c-.39 1.1-1.932 2.014-3.164 2.28-.842.18-1.94.322-5.642-1.212-4.738-1.962-7.792-6.778-8.03-7.094-.228-.316-1.916-2.554-1.916-4.872 0-2.318 1.212-3.456 1.642-3.928.39-.428 1.028-.626 1.638-.626.198 0 .376.01.536.018.47.02.706.048 1.016.788.39.926 1.338 3.244 1.456 3.48.118.236.236.554.078.87-.148.326-.278.47-.514.742-.236.272-.46.48-.696.774-.218.254-.462.526-.198.996.264.46 1.174 1.878 2.52 3.044 1.732 1.498 3.192 1.964 3.644 2.182.352.17.772.138 1.046-.158.348-.376.778-.998 1.214-1.614.312-.44.704-.494 1.094-.336.396.148 2.506 1.182 2.936 1.396.43.216.716.322.822.498.104.176.104 1.022-.286 2.122z"/>
      </svg>
    </a>
  </body>
</html>

<script>
  import Lenis from 'lenis';

  // Lenis smooth scroll
  const lenis = new Lenis({ duration: 1.2, easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)) });

  function raf(time: number) {
    lenis.raf(time);
    requestAnimationFrame(raf);
  }
  requestAnimationFrame(raf);

  // Reveal on scroll
  const revealEls = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1 }
  );
  revealEls.forEach((el) => observer.observe(el));

  // Spotlight cards — mouse tracking
  document.querySelectorAll<HTMLElement>('.spotlight-card').forEach((card) => {
    card.addEventListener('mousemove', (e) => {
      const rect = card.getBoundingClientRect();
      card.style.setProperty('--mouse-x', `${e.clientX - rect.left}px`);
      card.style.setProperty('--mouse-y', `${e.clientY - rect.top}px`);
    });
  });

  // Custom cursor
  const dot     = document.getElementById('cursor-dot') as HTMLElement | null;
  const outline = document.getElementById('cursor-outline') as HTMLElement | null;

  if (dot && outline && window.matchMedia('(hover: hover)').matches) {
    let cx = 0, cy = 0, ox = 0, oy = 0;

    document.addEventListener('mousemove', (e) => {
      cx = e.clientX;
      cy = e.clientY;
      dot.style.left = cx + 'px';
      dot.style.top  = cy + 'px';
    });

    function animateOutline() {
      ox += (cx - ox) * 0.12;
      oy += (cy - oy) * 0.12;
      outline!.style.left = ox + 'px';
      outline!.style.top  = oy + 'px';
      requestAnimationFrame(animateOutline);
    }
    animateOutline();

    document.querySelectorAll('a, button, [data-cursor]').forEach((el) => {
      el.addEventListener('mouseenter', () => outline?.classList.add('is-hovering'));
      el.addEventListener('mouseleave', () => outline?.classList.remove('is-hovering'));
    });
  }
</script>
