        </ul>
      </div>

      <div class="footer__col">
        <h4>Empresa</h4>
        <ul>
          <li><a href="/sobre">Sobre</a></li>
          <li><a href="/cases">Antes e Depois</a></li>
          <li><a href="/processo">Como Funciona</a></li>
          <li><a href="/blog">Blog</a></li>
          <li><a href="/contato">Contato</a></li>
        </ul>
      </div>

      <div class="footer__col">
        <h4>Contato</h4>
        <ul>
          <li>
            <a
              href="https://wa.me/5589994711318?text=Olá!%20Quero%20saber%20mais%20sobre%20reforma%20de%20site."
