---
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  internal?: boolean;
}
const { internal = false } = Astro.props;
const base = internal ? '' : '/';
---

<header class="navbar" id="navbar">
  <div class="container navbar__inner">
    <a href="/" class="navbar__logo" aria-label="Sites Especiais — Início">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true" class="navbar__logo-icon">
        <path d="M12 2L20.66 7v10L12 22 3.34 17V7z" fill="none" stroke="var(--primary)" stroke-width="1.5"/>
        <path d="M12 6L17.2 9v6L12 18 6.8 15V9z" fill="var(--primary)" opacity="0.15"/>
      </svg>
      <span>Sites<strong>Especiais</strong></span>
    </a>

    <nav class="navbar__links" id="nav-links" aria-label="Navegação principal">
      <!-- Dropdown Serviços -->
      <div class="navbar__dropdown-wrap" id="nav-servicos-wrap">
        <button
          class="navbar__dropdown-btn"
          id="nav-servicos-btn"
          aria-haspopup="true"
          aria-expanded="false"
          aria-controls="nav-servicos-menu"
        >
          Serviços
          <svg class="navbar__chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
            <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <div class="navbar__dropdown-menu" id="nav-servicos-menu" role="menu">
          <a href="/reforma" role="menuitem">
            <span class="dropdown-icon">🔧</span>
            <span>
              <strong>Reforma de Site</strong>
              <small>Site novo, mesmo domínio · 14 dias</small>
            </span>
          </a>
          <a href="/site-novo" role="menuitem">
            <span class="dropdown-icon">🚀</span>
            <span>
              <strong>Site Novo Premium</strong>
              <small>Do zero, feito para converter</small>
            </span>
          </a>
          <div class="dropdown-divider" aria-hidden="true"></div>
          <a href="/servicos/manutencao-site" role="menuitem">
            <span class="dropdown-icon">🛡️</span>
            <span>
              <strong>Manutenção Mensal</strong>
              <small>Site sempre no ar e atualizado</small>
            </span>
          </a>
          <a href="/servicos/seo-mensal" role="menuitem">
            <span class="dropdown-icon">📈</span>
            <span>
              <strong>SEO Mensal</strong>
              <small>Apareça no Google todo mês</small>
            </span>
          </a>
          <div class="dropdown-divider" aria-hidden="true"></div>
          <a href="/precos" role="menuitem" class="dropdown-link--muted">Ver todos os preços →</a>
        </div>
      </div>

      <a href={`${base}#como-funciona`}>Como Funciona</a>
      <a href={`${base}#cases`}>Antes e Depois</a>
      <a href="/blog">Blog</a>
      <a href="/sobre">Sobre</a>
    </nav>

    <div class="navbar__actions">
      <ThemeToggle />
      <a href="/diagnostico" class="btn btn--primary navbar__cta">
        Diagnóstico Grátis →
      </a>
    </div>

    <button
      class="navbar__toggle"
      id="nav-toggle"
      aria-label="Abrir menu de navegação"
      aria-expanded="false"
      aria-controls="nav-links"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</header>

<style>
.navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  padding: 1.2rem 0;
  transition: all 0.3s ease;
}

.navbar.scrolled {
  background: var(--surface-sticky);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--border);
  padding: 0.75rem 0;
}

.navbar__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 2rem;
}

.navbar__logo {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  font-family: var(--font-sans);
  font-size: 1.1rem;
  color: var(--text-primary);
  font-weight: 400;
  letter-spacing: -0.01em;
  flex-shrink: 0;
}

.navbar__logo strong { font-weight: 700; }

.navbar__logo-icon { flex-shrink: 0; }

.navbar__links {
  display: flex;
  align-items: center;
  gap: 1.8rem;
}

.navbar__links a {
  color: var(--text-secondary);
  font-size: 0.875rem;
  font-weight: 500;
  transition: color 0.2s;
  white-space: nowrap;
}

.navbar__links a:hover { color: var(--text-primary); }

/* ── Dropdown Serviços ──────────────────────────── */
.navbar__dropdown-wrap {
  position: relative;
}

.navbar__dropdown-btn {
  display: flex;
  align-items: center;
  gap: 0.35rem;
  color: var(--text-secondary);
  font-size: 0.875rem;
  font-weight: 500;
  font-family: var(--font-sans);
  background: none;
  border: none;
  cursor: pointer;
  padding: 0;
  transition: color 0.2s;
  white-space: nowrap;
}

.navbar__dropdown-btn:hover { color: var(--text-primary); }

.navbar__chevron {
  transition: transform 0.2s var(--ease-out);
  flex-shrink: 0;
}

.navbar__dropdown-wrap.is-open .navbar__chevron {
  transform: rotate(180deg);
}

.navbar__dropdown-menu {
  position: absolute;
  top: calc(100% + 0.75rem);
  left: 50%;
  transform: translateX(-50%);
  min-width: 260px;
  background: var(--card);
  backdrop-filter: blur(24px);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 0.5rem;
  display: none;
  flex-direction: column;
  gap: 0.125rem;
  box-shadow: 0 16px 40px rgba(0,0,0,0.6);
  z-index: 200;
}

.navbar__dropdown-wrap.is-open .navbar__dropdown-menu {
  display: flex;
}

.navbar__dropdown-menu a {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.65rem 0.75rem;
  border-radius: var(--radius-md);
  transition: background 0.15s;
  white-space: normal;
}

.navbar__dropdown-menu a:hover {
  background: var(--surface-glass);
  color: var(--text-primary);
}

.dropdown-icon {
  font-size: 1rem;
  flex-shrink: 0;
  width: 24px;
  text-align: center;
}

.navbar__dropdown-menu a span:not(.dropdown-icon) {
  display: flex;
  flex-direction: column;
  gap: 0.1rem;
}

.navbar__dropdown-menu a strong {
  font-size: 0.86rem;
  font-weight: 600;
  color: var(--foreground);
  line-height: 1.2;
}

.navbar__dropdown-menu a small {
  font-size: 0.74rem;
  color: var(--text-muted);
  line-height: 1.3;
}

.dropdown-divider {
  height: 1px;
  background: var(--border);
  margin: 0.25rem 0.5rem;
}

.dropdown-link--muted {
  font-size: 0.78rem !important;
  color: var(--text-muted) !important;
  justify-content: center;
  padding: 0.5rem !important;
}

.dropdown-link--muted:hover {
  color: var(--primary) !important;
}

.navbar__actions {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  flex-shrink: 0;
}

.navbar__cta {
  padding: 0.55rem 1.3rem;
  font-size: 0.82rem;
  flex-shrink: 0;
}

.navbar__toggle {
  display: none;
  flex-direction: column;
  gap: 5px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 4px;
}

.navbar__toggle span {
  width: 24px;
  height: 2px;
  background: var(--text-primary);
  border-radius: 2px;
  transition: all 0.25s var(--ease-out);
  display: block;
}

.navbar__toggle.active span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.navbar__toggle.active span:nth-child(2) { opacity: 0; }
.navbar__toggle.active span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

@media (max-width: 960px) {
  .navbar__links { display: none; }
  .navbar__cta   { display: none; }
  .navbar__actions { gap: 0.5rem; }
  .navbar__toggle { display: flex; }

  .navbar__links.active {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: var(--surface-sticky);
    backdrop-filter: blur(20px);
    padding: 2rem 1.5rem;
    gap: 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .navbar__links.active a {
    font-size: 1rem;
  }

  /* Dropdown no mobile — inline expandido */
  .navbar__dropdown-btn {
    font-size: 1rem;
    color: var(--text-secondary);
  }

  .navbar__dropdown-menu {
    position: static;
    transform: none;
    background: var(--surface-glass);
    border: 1px solid var(--border);
    padding: 0.5rem;
    width: 100%;
    box-shadow: none;
  }

  .navbar__dropdown-wrap.is-open .navbar__dropdown-menu {
    display: flex;
    margin-top: 0.5rem;
  }
}
</style>

<script>
  const navbar   = document.getElementById('navbar');
  const toggle   = document.getElementById('nav-toggle');
  const navLinks = document.getElementById('nav-links');

  window.addEventListener('scroll', () => {
    navbar?.classList.toggle('scrolled', window.scrollY > 40);
  });

  toggle?.addEventListener('click', () => {
    const isActive = navLinks?.classList.toggle('active');
    toggle.classList.toggle('active');
    toggle.setAttribute('aria-expanded', String(isActive));
  });

  // Fechar menu ao clicar em link interno
  navLinks?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      navLinks.classList.remove('active');
      toggle?.classList.remove('active');
      toggle?.setAttribute('aria-expanded', 'false');
    });
  });

  // Dropdown Serviços
  const dropBtn  = document.getElementById('nav-servicos-btn') as HTMLButtonElement | null;
  const dropWrap = document.getElementById('nav-servicos-wrap') as HTMLElement | null;

  dropBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    const isOpen = dropWrap?.classList.toggle('is-open');
    dropBtn.setAttribute('aria-expanded', String(isOpen));
  });

  // Fechar dropdown ao clicar fora
  document.addEventListener('click', (e) => {
    if (dropWrap && !dropWrap.contains(e.target as Node)) {
      dropWrap.classList.remove('is-open');
      dropBtn?.setAttribute('aria-expanded', 'false');
    }
  });

  // Fechar dropdown ao pressionar Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      dropWrap?.classList.remove('is-open');
      dropBtn?.setAttribute('aria-expanded', 'false');
    }
  });
</script>
