---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { getAllCases, getAllCaseSlugs, getCaseBySlug } from '../../lib/content';

export async function getStaticPaths() {
  const slugs = await getAllCaseSlugs();
  return slugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const [c, allCases] = await Promise.all([getCaseBySlug(slug), getAllCases()]);

if (!c) return Astro.redirect('/cases');

const rotulo = c.servico === 'reforma' ? 'Reforma de Site' : 'Site Novo Premium';
---

<Layout
  title={`Case ${c.nome} — Sites Especiais`}
  description={c.resumo}
>
  <Navbar />

  <main style="position: relative; z-index: 1;">

    <!-- Cabeçalho -->
    <section class="section case-hero">
      <div class="container container--narrow">
        <div class="case-breadcrumb reveal">
          <a href="/cases">Cases</a>
          <span>›</span>
          <span>{c.nome}</span>
        </div>

        <div class="case-tags reveal reveal-delay-1">
          <span class="case-tag">{c.setor}</span>
          <span class="case-tag">{c.cidade}</span>
          <span class="case-tag case-tag--servico">{rotulo}</span>
        </div>

        <h1 class="case-hero__h1 reveal reveal-delay-2">{c.nome}</h1>
        <p class="case-hero__resumo reveal reveal-delay-3">{c.resumo}</p>
      </div>
    </section>

    <!-- Métricas destaque -->
    <section class="case-metricas-section reveal">
      <div class="container">
        <div class="case-metricas-grid">
          {c.metricas.map((m) => (
            <div class="case-metrica-item">
              <span class="case-metrica-val" style={`color: ${c.cor}`}>{m.valor}</span>
              <span class="case-metrica-label">{m.label}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Conteúdo principal -->
    <section class="section">
      <div class="container case-layout">
        <div class="case-main">

          <!-- Desafio -->
          <div class="case-block reveal">
            <h2 class="case-block__title">
              <span class="case-block__num">01</span>
              O desafio
            </h2>
            <p class="case-block__text">{c.desafio}</p>
          </div>

          <!-- Antes/Depois lista -->
          <div class="case-ad reveal">
            <div class="case-ad__col">
              <p class="case-ad__label case-ad__label--antes">Antes</p>
              <ul class="case-ad__list">
                {c.antes.map((item) => (
                  <li><span class="case-x">✗</span>{item}</li>
                ))}
              </ul>
            </div>
            <div class="case-ad__col">
              <p class="case-ad__label case-ad__label--depois">Depois</p>
              <ul class="case-ad__list">
                {c.depois.map((item) => (
                  <li><span class="case-check">✓</span>{item}</li>
                ))}
              </ul>
            </div>
          </div>

          <!-- Solução -->
          <div class="case-block reveal">
            <h2 class="case-block__title">
              <span class="case-block__num">02</span>
              A solução
            </h2>
            <p class="case-block__text">{c.solucao}</p>
          </div>

          <!-- Resultado -->
          <div class="case-block reveal">
            <h2 class="case-block__title">
              <span class="case-block__num">03</span>
              O resultado
            </h2>
            <p class="case-block__text">{c.resultado}</p>
          </div>

          <!-- Depoimento -->
          {c.depoimento && (
            <blockquote class="case-depoimento reveal">
              <div class="case-depoimento__stars">★★★★★</div>
              <p class="case-depoimento__texto">"{c.depoimento.texto}"</p>
              <footer class="case-depoimento__autor">
                <div class="case-depoimento__avatar">
                  {c.depoimento.autor.split(' ').map(w => w[0]).slice(0, 2).join('')}
                </div>
                <div>
                  <strong>{c.depoimento.autor}</strong>
                  <span>{c.depoimento.cargo}</span>
                </div>
              </footer>
            </blockquote>
          )}
        </div>

        <!-- Sidebar -->
        <aside class="case-sidebar">
          <div class="sidebar-card">
            <p class="sidebar-card__title">Quer resultados como esses?</p>
            <p class="sidebar-card__desc">
              Diagnóstico gratuito. Resultado em 14 dias. Garantia incondicional de 7 dias.
            </p>
            <a href="/diagnostico" class="btn btn--primary" style="width: 100%; justify-content: center; margin-top: 1.25rem;">
              Diagnóstico Gratuito →
            </a>
            <a href="https://wa.me/5589994711318" target="_blank" rel="noopener" class="btn btn--ghost" style="width: 100%; justify-content: center; margin-top: 0.5rem; font-size: 0.85rem;">
              Falar no WhatsApp
            </a>
          </div>

          <div class="sidebar-card" style="margin-top: 1.25rem;">
            <p class="sidebar-card__title">Serviço</p>
            <span class="sidebar-tag">{rotulo}</span>
            <p class="sidebar-card__title" style="margin-top: 1rem;">Setor</p>
            <span class="sidebar-tag">{c.setor}</span>
            <p class="sidebar-card__title" style="margin-top: 1rem;">Localização</p>
            <span class="sidebar-tag">{c.cidade}</span>
          </div>
        </aside>
      </div>
    </section>

    <!-- Outros cases -->
    <section class="section section--alt">
      <div class="container">
        <h2 class="reveal" style="font-size: clamp(1.4rem, 2.5vw, 2rem); margin-bottom: 2rem; text-align: center;">
          Outros cases
        </h2>
        <div class="outros-cases">
          {allCases.filter((x) => x.slug !== c.slug).map((x) => (
            <a href={`/cases/${x.slug}`} class="outro-case reveal">
              <span class="outro-case__setor">{x.setor}</span>
              <span class="outro-case__nome">{x.nome}</span>
              <span class="outro-case__metrica" style={`color: ${x.cor}`}>
                {x.metricas[0].valor} {x.metricas[0].label}
              </span>
              <span class="outro-case__cta">Ver case →</span>
            </a>
          ))}
        </div>

        <div style="text-align: center; margin-top: 3rem;">
          <a href="/diagnostico" class="btn btn--primary btn--large reveal">
            Quero resultados assim →
          </a>
        </div>
      </div>
    </section>
  </main>

  <!-- Schema JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": `Case ${c.nome} — ${c.setor}`,
    "description": c.resumo,
    "author": {
      "@type": "Organization",
      "name": "Sites Especiais"
    },
    "publisher": {
      "@type": "Organization",
      "name": "Sites Especiais",
      "url": "https://sitesespeciais.com.br"
    }
  })} />

  <Footer />
</Layout>

<style>
.section--alt { background: rgba(255, 255, 255, 0.015); }

/* Breadcrumb */
.case-breadcrumb {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.8rem;
  color: var(--text-muted);
  margin-bottom: 1.25rem;
}
.case-breadcrumb a { color: var(--luxota-accent); text-decoration: none; }
.case-breadcrumb a:hover { text-decoration: underline; }

.case-tags {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
  margin-bottom: 1rem;
}

.case-tag {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  padding: 0.25rem 0.75rem;
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid var(--border);
  border-radius: 100px;
  color: var(--text-muted);
}

.case-tag--servico {
  background: rgba(79, 209, 197, 0.07);
  border-color: var(--luxota-border);
  color: var(--luxota-accent);
}

.case-hero { padding-bottom: 0; }

.case-hero__h1 {
  font-size: clamp(2rem, 4.5vw, 3.5rem);
  line-height: 1.1;
  margin-bottom: 1rem;
}

.case-hero__resumo {
  font-size: 1.1rem;
  color: var(--text-secondary);
  line-height: 1.7;
  max-width: 620px;
}

/* Métricas */
.case-metricas-section {
  background: var(--card);
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
  padding: 2.5rem 0;
}

.case-metricas-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1px;
  background: var(--border);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  overflow: hidden;
}

@media (max-width: 640px) { .case-metricas-grid { grid-template-columns: repeat(2, 1fr); } }

.case-metrica-item {
  background: var(--card);
  padding: 1.5rem;
  text-align: center;
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
}

.case-metrica-val {
  font-family: var(--font-mono);
  font-size: 2rem;
  font-weight: 700;
  line-height: 1;
}

.case-metrica-label {
  font-size: 0.76rem;
  color: var(--text-muted);
  line-height: 1.4;
}

/* Layout principal */
.case-layout {
  display: grid;
  grid-template-columns: 1fr 280px;
  gap: 3rem;
  align-items: start;
}

@media (max-width: 900px) {
  .case-layout { grid-template-columns: 1fr; }
  .case-sidebar { order: -1; }
}

/* Blocos de conteúdo */
.case-main { display: flex; flex-direction: column; gap: 3rem; }

.case-block__title {
  font-family: var(--font-sans);
  font-size: 1.2rem;
  font-weight: 700;
  color: var(--foreground);
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-bottom: 1rem;
}

.case-block__num {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  color: var(--primary);
  opacity: 0.6;
}

.case-block__text {
  font-size: 0.95rem;
  color: var(--text-secondary);
  line-height: 1.75;
}

/* Antes/Depois */
.case-ad {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.5rem;
  padding: 1.5rem;
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
}

@media (max-width: 540px) { .case-ad { grid-template-columns: 1fr; } }

.case-ad__label {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  margin-bottom: 0.75rem;
}

.case-ad__label--antes { color: var(--error); }
.case-ad__label--depois { color: var(--success); }

.case-ad__list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.case-ad__list li {
  display: flex;
  gap: 0.5rem;
  font-size: 0.88rem;
  color: var(--text-secondary);
  line-height: 1.5;
}

.case-x     { color: var(--error);   flex-shrink: 0; }
.case-check { color: var(--success); flex-shrink: 0; }

/* Depoimento */
.case-depoimento {
  background: linear-gradient(135deg, rgba(232,197,71,0.05) 0%, var(--card) 60%);
  border: 1px solid rgba(232, 197, 71, 0.2);
  border-radius: var(--radius-xl);
  padding: 2rem;
  margin: 0;
}

.case-depoimento__stars { color: var(--primary); margin-bottom: 1rem; }

.case-depoimento__texto {
  font-size: 1rem;
  color: var(--foreground);
  line-height: 1.75;
  font-style: italic;
  margin-bottom: 1.5rem;
}

.case-depoimento__autor {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding-top: 1rem;
  border-top: 1px solid rgba(232, 197, 71, 0.15);
}

.case-depoimento__avatar {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary), var(--luxota-accent));
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-mono);
  font-size: 0.72rem;
  font-weight: 700;
  color: var(--luxota-bg);
  flex-shrink: 0;
}

.case-depoimento__autor strong { display: block; font-size: 0.9rem; color: var(--foreground); }
.case-depoimento__autor span  { display: block; font-size: 0.78rem; color: var(--text-muted); }

/* Sidebar */
.case-sidebar { position: sticky; top: 6rem; }

.sidebar-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 1.5rem;
}

.sidebar-card__title {
  font-size: 0.78rem;
  font-weight: 600;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin-bottom: 0.5rem;
}

.sidebar-card__desc { font-size: 0.84rem; color: var(--text-secondary); line-height: 1.55; }

.sidebar-tag {
  font-family: var(--font-mono);
  font-size: 0.78rem;
  color: var(--foreground);
}

/* Outros cases */
.outros-cases {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1rem;
  max-width: 700px;
  margin-inline: auto;
}

@media (max-width: 540px) { .outros-cases { grid-template-columns: 1fr; } }

.outro-case {
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
  padding: 1.5rem;
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  text-decoration: none;
  transition: border-color 0.3s, transform 0.3s;
}

.outro-case:hover {
  border-color: rgba(79, 209, 197, 0.2);
  transform: translateY(-2px);
}

.outro-case__setor {
  font-family: var(--font-mono);
  font-size: 0.68rem;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

.outro-case__nome {
  font-family: var(--font-sans);
  font-size: 1rem;
  font-weight: 700;
  color: var(--foreground);
}

.outro-case__metrica {
  font-family: var(--font-mono);
  font-size: 0.8rem;
  font-weight: 600;
}

.outro-case__cta {
  font-size: 0.82rem;
  color: var(--luxota-accent);
  margin-top: 0.25rem;
}
</style>
