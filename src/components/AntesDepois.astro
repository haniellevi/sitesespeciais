---
const cases = [
  {
    id: 'fiel',
    nome: 'Fiel Alimentos',
    setor: 'Distribuidora de alimentos · Piauí',
    tipo: 'REFORMA',
    problemas: [
      'Site de 2018 sem atualização — parecia empresa fechada',
      'Invisível em buscas de distribuidores e parceiros',
      'Único canal de contato: telefone e indicação',
      'Sem página ou formulário de proposta de parceria',
    ],
    resultados: [
      'Primeiro pedido pelo formulário em 45 dias no ar',
      'Distribuidores de outras regiões chegando pelo Google',
      'Formulário de parceria virou canal de vendas ativo',
      'Google e IAs validam a empresa antes de qualquer reunião',
    ],
    metricas: [
      { valor: '+340%', label: 'visitas em 60 dias' },
      { valor: '45 dias', label: '1° pedido pelo site' },
      { valor: '14 dias', label: 'da aprovação ao ar' },
    ],
  },
  {
    id: 'emcorr',
    nome: 'EmCORR Centro Clínico',
    setor: 'Saúde · Corrente, PI',
    tipo: 'REFORMA',
    problemas: [
      'Presença digital desatualizada — especialidades desconhecidas',
      'Pacientes de cidades vizinhas não sabiam que a clínica existia',
      'Zero agendamentos digitais — dependência total de indicação',
      'Concorrentes de outras cidades dominavam as buscas locais',
    ],
    resultados: [
      '8 especialidades indexadas e encontradas no Google',
      'Pacientes chegando toda semana de cidades vizinhas',
      'Agendamentos via WhatsApp triplicaram em 2 meses',
      'Referência de saúde digital na região de Corrente',
    ],
    metricas: [
      { valor: '3×', label: 'mais agendamentos' },
      { valor: '8', label: 'especialidades no Google' },
      { valor: '2 meses', label: 'retorno do investimento' },
    ],
  },
  {
    id: 'clinica',
    nome: 'Clínica Pinheiro',
    setor: 'Clínica médica · Bom Jesus, PI',
    tipo: 'SITE NOVO',
    problemas: [
      'Layout desatualizado afastando pacientes exigentes',
      'Apenas 3–4 agendamentos por semana pelo digital',
      'Invisível no Google — zero aparecer em busca local',
      'Novos pacientes chegavam só por indicação de conhecidos',
    ],
    resultados: [
      '15+ agendamentos por semana a partir do primeiro mês',
      '1ª página do Google para 8 palavras-chave locais',
      'Design que transmite confiança antes de qualquer contato',
      'Investimento pago no primeiro mês de operação',
    ],
    metricas: [
      { valor: '3×', label: 'mais agendamentos' },
      { valor: '8', label: 'keywords na 1ª página' },
      { valor: '1 mês', label: 'para pagar o investimento' },
    ],
  },
];
---

<section class="section" id="cases">
  <div class="container">

    <div class="text-center reveal" style="margin-bottom: 3.5rem;">
      <p class="eyebrow">Cases reais</p>
      <h2 class="section__h2">
        De problema<br>
        <span class="text-gradient-gold">a resultado comprovado.</span>
      </h2>
      <p class="section__sub">
        Não vendemos promessa de resultado.<br>
        Aqui estão os números reais de três empresas piauienses que contrataram.
      </p>
    </div>

    <div class="cases-tabs reveal">
      {cases.map((c, i) => (
        <button
          class={`case-tab${i === 0 ? ' is-active' : ''}`}
          data-case={c.id}
          aria-selected={i === 0 ? 'true' : 'false'}
          role="tab"
        >
          <span class="tab-nome">{c.nome}</span>
          <span class={`tab-tipo tab-tipo--${c.tipo === 'REFORMA' ? 'reforma' : 'novo'}`}>{c.tipo}</span>
        </button>
      ))}
    </div>

    {cases.map((c, i) => (
      <div
        class={`case-panel${i === 0 ? ' is-active' : ''}`}
        id={`case-${c.id}`}
        data-panel={c.id}
        role="tabpanel"
        aria-label={c.nome}
      >
        <!-- Cabeçalho do case -->
        <div class="case-header">
          <div class="case-header__info">
            <h3 class="case-nome">{c.nome}</h3>
            <p class="case-setor">{c.setor}</p>
          </div>
          <div class={`tipo-badge tipo-badge--${c.tipo === 'REFORMA' ? 'reforma' : 'novo'}`}>
            {c.tipo === 'REFORMA' ? 'Reforma de Site' : 'Site Novo'}
          </div>
        </div>

        <!-- Antes / Depois -->
        <div class="case-split">
          <div class="case-col case-col--antes">
            <div class="case-col__header">
              <span class="case-col__label">Antes</span>
            </div>
            <ul class="case-col__list">
              {c.problemas.map(p => (
                <li>
                  <span class="case-icon case-icon--x" aria-hidden="true">
                    <svg width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
                      <line x1="1" y1="1" x2="9" y2="9"/><line x1="9" y1="1" x2="1" y2="9"/>
                    </svg>
                  </span>
                  <span>{p}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="case-arrow-wrap" aria-hidden="true">
            <svg class="case-arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </div>

          <div class="case-col case-col--depois">
            <div class="case-col__header">
              <span class="case-col__label case-col__label--depois">Depois</span>
            </div>
            <ul class="case-col__list">
              {c.resultados.map(r => (
                <li>
                  <span class="case-icon case-icon--check" aria-hidden="true">
                    <svg width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="1.5,5 4,8 8.5,2"/>
                    </svg>
                  </span>
                  <span>{r}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <!-- Métricas -->
        <div class="case-metricas">
          {c.metricas.map(m => (
            <div class="case-metrica">
              <span class="case-metrica-valor">{m.valor}</span>
              <span class="case-metrica-label">{m.label}</span>
            </div>
          ))}
        </div>
      </div>
    ))}

    <div class="text-center" style="margin-top: 3rem;">
      <a href="/diagnostico" class="btn btn--primary btn--large reveal">
        Quero resultados assim →
      </a>
    </div>
  </div>
</section>

<style>
/* ── Tabs ─────────────────────────────────────────────── */
.cases-tabs {
  display: flex;
  gap: 0.5rem;
  border-bottom: 1px solid var(--border);
  margin-bottom: 2.5rem;
  flex-wrap: wrap;
}

.case-tab {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 0.2rem;
  padding: 0.75rem 1.25rem 0.85rem;
  background: none;
  border: none;
  border-bottom: 2px solid transparent;
  color: var(--text-muted);
  font-family: var(--font-sans);
  font-size: 0.9rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.25s var(--ease-out);
  margin-bottom: -1px;
  text-align: left;
}

.tab-nome { line-height: 1.2; }

.tab-tipo {
  font-family: var(--font-mono);
  font-size: 0.62rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-muted);
}

.tab-tipo--reforma { color: var(--luxota-accent); }
.tab-tipo--novo    { color: var(--primary); }

.case-tab.is-active,
.case-tab:hover {
  color: var(--foreground);
  border-bottom-color: var(--primary);
}

.case-tab.is-active .tab-tipo { color: var(--text-secondary); }

/* ── Panel ────────────────────────────────────────────── */
.case-panel { display: none; }
.case-panel.is-active { display: block; }

/* ── Header ───────────────────────────────────────────── */
.case-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 1rem;
  margin-bottom: 1.75rem;
  flex-wrap: wrap;
}

.case-nome {
  font-family: var(--font-sans);
  font-size: 1.15rem;
  font-weight: 700;
  color: var(--foreground);
  margin-bottom: 0.2rem;
  line-height: 1.2;
}

.case-setor {
  font-size: 0.82rem;
  color: var(--text-muted);
  margin: 0;
  font-family: var(--font-mono);
}

.tipo-badge {
  font-family: var(--font-mono);
  font-size: 0.67rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  padding: 0.3rem 0.85rem;
  border-radius: 100px;
  white-space: nowrap;
  flex-shrink: 0;
}

.tipo-badge--reforma {
  background: rgba(79, 209, 197, 0.08);
  border: 1px solid rgba(79, 209, 197, 0.2);
  color: var(--luxota-accent);
}

.tipo-badge--novo {
  background: rgba(240, 208, 96, 0.08);
  border: 1px solid rgba(240, 208, 96, 0.2);
  color: var(--primary);
}

/* ── Split antes/depois ───────────────────────────────── */
.case-split {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  gap: 1rem;
  align-items: start;
  margin-bottom: 2rem;
}

@media (max-width: 640px) {
  .case-split {
    grid-template-columns: 1fr;
  }
  .case-arrow-wrap { text-align: center; padding: 0.5rem 0; }
}

.case-col {
  border-radius: var(--radius-lg);
  overflow: hidden;
}

.case-col--antes {
  border: 1px solid rgba(229, 62, 62, 0.15);
  background: rgba(229, 62, 62, 0.03);
}

.case-col--depois {
  border: 1px solid rgba(79, 209, 197, 0.18);
  background: rgba(79, 209, 197, 0.03);
}

.case-col__header {
  padding: 0.65rem 1.25rem;
  border-bottom: 1px solid rgba(255,255,255,0.04);
}

.case-col__label {
  font-family: var(--font-mono);
  font-size: 0.66rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: rgba(229, 62, 62, 0.7);
}

.case-col--antes .case-col__header { border-bottom-color: rgba(229, 62, 62, 0.08); }
.case-col--depois .case-col__header { border-bottom-color: rgba(79, 209, 197, 0.08); }

.case-col__label--depois {
  color: var(--luxota-accent);
}

.case-col__list {
  list-style: none;
  padding: 1rem 1.25rem;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.case-col__list li {
  display: flex;
  align-items: flex-start;
  gap: 0.65rem;
  font-size: 0.86rem;
  color: var(--text-secondary);
  line-height: 1.5;
}

.case-icon {
  width: 18px;
  height: 18px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 0.05rem;
}

.case-icon--x {
  background: rgba(229, 62, 62, 0.1);
  border: 1px solid rgba(229, 62, 62, 0.2);
  color: #e53e3e;
}

.case-icon--check {
  background: rgba(79, 209, 197, 0.1);
  border: 1px solid rgba(79, 209, 197, 0.2);
  color: var(--luxota-accent);
}

/* ── Arrow ────────────────────────────────────────────── */
.case-arrow-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  padding-top: 3.5rem;
}

.case-arrow {
  color: var(--primary);
  opacity: 0.5;
}

/* ── Métricas ─────────────────────────────────────────── */
.case-metricas {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  background: var(--border);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  overflow: hidden;
}

@media (max-width: 480px) {
  .case-metricas { grid-template-columns: 1fr; }
}

.case-metrica {
  background: var(--card);
  padding: 1.5rem;
  text-align: center;
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
}

.case-metrica-valor {
  font-family: var(--font-mono);
  font-size: 1.8rem;
  font-weight: 600;
  color: var(--primary);
  line-height: 1;
}

.case-metrica-label {
  font-size: 0.78rem;
  color: var(--text-muted);
  line-height: 1.4;
}
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('.case-tab').forEach((tab) => {
    tab.addEventListener('click', () => {
      const id = tab.dataset.case;

      document.querySelectorAll('.case-tab').forEach((t) => {
        t.classList.remove('is-active');
        t.setAttribute('aria-selected', 'false');
      });
      document.querySelectorAll('.case-panel').forEach((p) => p.classList.remove('is-active'));

      tab.classList.add('is-active');
      tab.setAttribute('aria-selected', 'true');
      document.getElementById(`case-${id}`)?.classList.add('is-active');
    });
  });
</script>
