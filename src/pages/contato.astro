---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Contato — Sites Especiais | Fale diretamente com quem faz"
  description="WhatsApp, email ou agendamento direto. Sem formulário de triagem, sem chatbot. Você fala com quem vai fazer o seu site."
>
  <Navbar />

  <main style="position: relative; z-index: 1;">

    <!-- HERO -->
    <section class="section contato-hero">
      <div class="perspective-grid" aria-hidden="true"></div>
      <div class="container container--narrow text-center" style="position: relative; z-index: 1;">

        <p class="eyebrow reveal">Contato</p>

        <h1 class="contato__h1 reveal reveal-delay-1">
          Fale diretamente<br>
          <span class="text-gradient">com quem faz.</span>
        </h1>

        <p class="contato__sub reveal reveal-delay-2">
          Sem chatbot, sem formulário que cai num SAC genérico.
          Você fala direto comigo — a mesma pessoa que vai criar ou reformar o seu site.
        </p>
      </div>
    </section>

    <!-- CANAIS DE CONTATO -->
    <section class="section">
      <div class="container container--narrow">
        <div class="canais-grid">

          <!-- WhatsApp - principal -->
          <a
            href="https://wa.me/5589994711318?text=Ol%C3%A1%2C%20gostaria%20de%20conversar%20sobre%20o%20meu%20site."
            target="_blank"
            rel="noopener"
            class="canal-card canal-card--destaque reveal"
          >
            <div class="canal-card__icon-wrap">
              <svg width="22" height="22" viewBox="0 0 32 32" fill="currentColor" aria-hidden="true">
                <path d="M16.004 0h-.008C7.174 0 0 7.176 0 16.004c0 3.5 1.128 6.744 3.046 9.378L1.054 31.29l6.118-1.958A15.932 15.932 0 0016.004 32C24.826 32 32 24.826 32 16.004S24.826 0 16.004 0zm9.334 22.616c-.39 1.1-1.932 2.014-3.164 2.28-.842.18-1.94.322-5.642-1.212-4.738-1.962-7.792-6.778-8.03-7.094-.228-.316-1.916-2.554-1.916-4.872 0-2.318 1.212-3.456 1.642-3.928.39-.428 1.028-.626 1.638-.626.198 0 .376.01.536.018.47.02.706.048 1.016.788.39.926 1.338 3.244 1.456 3.48.118.236.236.554.078.87-.148.326-.278.47-.514.742-.236.272-.46.48-.696.774-.218.254-.462.526-.198.996.264.46 1.174 1.878 2.52 3.044 1.732 1.498 3.192 1.964 3.644 2.182.352.17.772.138 1.046-.158.348-.376.778-.998 1.214-1.614.312-.44.704-.494 1.094-.336.396.148 2.506 1.182 2.936 1.396.43.216.716.322.822.498.104.176.104 1.022-.286 2.122z"/>
              </svg>
            </div>
            <div class="canal-card__content">
              <div class="canal-card__label">WhatsApp</div>
              <div class="canal-card__titulo">Resposta em até 1 hora</div>
              <p class="canal-card__desc">
                Melhor canal para dúvidas rápidas, orçamentos e conversa inicial.
                Segunda a sexta, das 8h às 18h (BRT).
              </p>
            </div>
            <div class="canal-card__arrow">→</div>
          </a>

          <!-- Diagnóstico -->
          <a
            href="/diagnostico"
            class="canal-card reveal reveal-delay-1"
          >
            <div class="canal-card__icon-wrap">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M9 11l3 3L22 4"/>
                <path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/>
              </svg>
            </div>
            <div class="canal-card__content">
              <div class="canal-card__label">Diagnóstico gratuito</div>
              <div class="canal-card__titulo">Análise em até 24h úteis</div>
              <p class="canal-card__desc">
                Preencha o formulário com as informações do seu negócio. Nossa equipe analisa seu site e envia o diagnóstico por e-mail e WhatsApp. Gratuito, sem compromisso.
              </p>
            </div>
            <div class="canal-card__arrow">→</div>
          </a>

          <!-- Email -->
          <a
            href="mailto:contato@sitesespeciais.com.br"
            class="canal-card reveal reveal-delay-2"
          >
            <div class="canal-card__icon-wrap">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
            </div>
            <div class="canal-card__content">
              <div class="canal-card__label">Email</div>
              <div class="canal-card__titulo">contato@sitesespeciais.com.br</div>
              <p class="canal-card__desc">
                Para enviar materiais, briefing ou assuntos que precisam de detalhamento.
                Resposta em até 24h úteis.
              </p>
            </div>
            <div class="canal-card__arrow">→</div>
          </a>

        </div>
      </div>
    </section>

    <!-- HORÁRIO E LOCALIZAÇÃO -->
    <section class="section section--alt">
      <div class="container container--narrow">
        <div class="info-grid">
          <div class="info-item reveal">
            <div class="info-item__icon-wrap" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
              </svg>
            </div>
            <div>
              <h3>Horário de atendimento</h3>
              <p>Segunda a sexta: 8h às 18h (BRT)<br>Não trabalhamos aos sábados.</p>
            </div>
          </div>
          <div class="info-item reveal reveal-delay-1">
            <div class="info-item__icon-wrap" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="10" r="3"/><path d="M12 2a8 8 0 010 16c-4.418 0-8-3.582-8-8s3.582-8 8-8z" opacity=".4"/><path d="M12 21v1"/>
              </svg>
            </div>
            <div>
              <h3>Onde atendemos</h3>
              <p>Piauí, Brasil — atendemos remotamente toda a América Latina.</p>
            </div>
          </div>
          <div class="info-item reveal reveal-delay-2">
            <div class="info-item__icon-wrap" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
              </svg>
            </div>
            <div>
              <h3>Tempo de resposta</h3>
              <p>WhatsApp: até 1h<br>Email: até 24h úteis<br>Diagnóstico: 24h após o envio do formulário</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ RÁPIDO -->
    <section class="section">
      <div class="container container--narrow">
        <div class="text-center reveal" style="margin-bottom: 2rem;">
          <p class="eyebrow">Antes de entrar em contato</p>
          <h2 class="section__h2">Respostas rápidas.</h2>
        </div>

        <div class="faq-rapido">
          <div class="faq-r-item reveal">
            <strong>Qual o prazo de entrega?</strong>
            <p>Reforma: 14 dias corridos. Site novo: 21 dias corridos. Ambos em contrato.</p>
          </div>
          <div class="faq-r-item reveal reveal-delay-1">
            <strong>Qual o preço?</strong>
            <p>Reforma a partir de R$ 1.997. Site novo a partir de R$ 2.997. Parcelamento em 10x no cartão. <a href="/precos">Ver tabela de preços →</a></p>
          </div>
          <div class="faq-r-item reveal reveal-delay-2">
            <strong>Tem garantia?</strong>
            <p>Sim. 7 dias incondicional. Se não gostar por qualquer razão, devolvemos 100%. <a href="/garantia">Como funciona →</a></p>
          </div>
          <div class="faq-r-item reveal">
            <strong>Atende empresas de fora do Brasil?</strong>
            <p>Sim. Todo o trabalho é remoto. Atendemos empresas em toda a América Latina.</p>
          </div>
          <div class="faq-r-item reveal reveal-delay-1">
            <strong>Preciso ter um site para contratar?</strong>
            <p>Não. Tanto a Reforma (site existente) quanto o Site Novo (do zero) estão disponíveis.</p>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style>
.text-center { text-align: center; }
.section--alt { background: rgba(255,255,255,0.015); }

.eyebrow {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--luxota-accent);
  margin-bottom: 0.75rem;
}

.section__h2 {
  font-size: clamp(1.8rem, 3.5vw, 2.6rem);
  margin-bottom: 1rem;
}

/* Hero */
.contato-hero {
  padding-top: 9rem;
  padding-bottom: 5rem;
  position: relative;
  overflow: hidden;
}

.contato__h1 {
  font-family: 'Playfair Display', serif;
  font-size: clamp(2.6rem, 6vw, 4.5rem);
  line-height: 1.06;
  letter-spacing: -0.02em;
  margin-bottom: 1.5rem;
}

.contato__sub {
  font-size: clamp(1rem, 1.5vw, 1.1rem);
  color: var(--text-secondary);
  line-height: 1.7;
  max-width: 520px;
  margin-inline: auto;
}

/* Canais */
.canais-grid { display: flex; flex-direction: column; gap: 1rem; }

.canal-card {
  display: flex;
  align-items: flex-start;
  gap: 1.25rem;
  padding: 1.75rem;
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--radius-xl);
  text-decoration: none;
  transition: border-color 0.2s, background 0.2s, transform 0.2s;
  position: relative;
  overflow: hidden;
}

.canal-card:hover {
  border-color: rgba(232, 197, 71, 0.3);
  background: rgba(232, 197, 71, 0.02);
  transform: translateY(-1px);
}

.canal-card--destaque {
  border-color: rgba(232, 197, 71, 0.25);
  background: rgba(232, 197, 71, 0.02);
  box-shadow: 0 0 40px rgba(232, 197, 71, 0.05);
}

.canal-card--destaque:hover {
  border-color: rgba(232, 197, 71, 0.5);
}

.canal-card__icon-wrap {
  width: 44px;
  height: 44px;
  background: rgba(240, 208, 96, 0.07);
  border: 1px solid rgba(240, 208, 96, 0.15);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--primary);
  flex-shrink: 0;
  margin-top: 0.1rem;
}

.canal-card--destaque .canal-card__icon-wrap {
  background: rgba(37, 211, 102, 0.08);
  border-color: rgba(37, 211, 102, 0.2);
  color: #25D366;
}

.canal-card__content { flex: 1; }

.canal-card__label {
  font-family: var(--font-mono);
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--luxota-accent);
  margin-bottom: 0.25rem;
}

.canal-card--destaque .canal-card__label { color: var(--primary); }

.canal-card__titulo {
  font-size: 1rem;
  font-weight: 700;
  color: var(--foreground);
  margin-bottom: 0.4rem;
  line-height: 1.3;
}

.canal-card__desc {
  font-size: 0.84rem;
  color: var(--text-muted);
  line-height: 1.55;
  margin: 0;
}

.canal-card__arrow {
  font-size: 0.9rem;
  color: var(--primary);
  margin-left: auto;
  flex-shrink: 0;
  opacity: 0.5;
  transition: opacity 0.2s, transform 0.2s;
  align-self: center;
}

.canal-card:hover .canal-card__arrow {
  opacity: 1;
  transform: translateX(3px);
}

/* Info grid */
.info-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 1.5rem;
}

.info-item { display: flex; gap: 1rem; align-items: flex-start; }

.info-item__icon-wrap {
  width: 36px;
  height: 36px;
  background: rgba(240, 208, 96, 0.07);
  border: 1px solid rgba(240, 208, 96, 0.12);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--primary);
  flex-shrink: 0;
  margin-top: 0.1rem;
}

.info-item h3 {
  font-size: 0.95rem;
  font-weight: 700;
  color: var(--foreground);
  margin-bottom: 0.3rem;
  line-height: 1.3;
}

.info-item p {
  font-size: 0.84rem;
  color: var(--text-secondary);
  line-height: 1.6;
  margin: 0;
}

/* FAQ rápido */
.faq-rapido {
  display: flex;
  flex-direction: column;
  gap: 0;
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--radius-xl);
  overflow: hidden;
}

.faq-r-item {
  padding: 1.25rem 1.5rem;
  border-bottom: 1px solid var(--border);
}

.faq-r-item:last-child { border-bottom: none; }

.faq-r-item strong {
  display: block;
  font-size: 0.93rem;
  color: var(--foreground);
  margin-bottom: 0.2rem;
}

.faq-r-item p {
  font-size: 0.84rem;
  color: var(--text-muted);
  line-height: 1.55;
  margin: 0;
}

.faq-r-item a {
  color: var(--primary);
  text-decoration: none;
  font-size: 0.82rem;
}

.faq-r-item a:hover { text-decoration: underline; }
</style>
